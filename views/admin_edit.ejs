<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin Panel • BookHub</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css"/>
</head>
<body>

<div id="toastx" class="toastx">
  <div class="dot"></div>
  <div>
    <p class="t-title">Done</p>
    <p class="t-sub">Action completed</p>
  </div>
</div>

<div class="container-xxl py-4">

  <nav class="navbar nav-glass px-3 py-2 mb-4">
    <div class="d-flex align-items-center gap-2">
      <a href="/" class="brand-badge">B</a>
      <div class="fw-bold">BookHub</div>
      <span class="badge-soft ms-2"><i class="bi bi-gear me-1"></i> Admin Panel</span>
    </div>
    <div class="ms-auto d-flex gap-2">
      <a class="btn btn-ghost btn-sm btn-ripple" href="/books"><i class="bi bi-grid-3x3-gap me-1"></i> Catalog</a>
      <a class="btn btn-brand btn-sm btn-ripple" href="/admin/logout"><i class="bi bi-box-arrow-right me-1"></i> Logout</a>
    </div>
  </nav>

  <!-- Add Book -->
  <div class="cardx mb-4 hover-lift">
    <div class="body">
      <div class="d-flex align-items-center justify-content-between mb-2">
        <div>
          <div class="title">Add New Book</div>
          <div class="sub">Admin can add / edit / delete books</div>
        </div>
        <span class="badge-soft"><i class="bi bi-plus-circle me-1"></i> Create</span>
      </div>

      <form class="row g-2" method="POST" action="/admin/books/add">
        <div class="col-md-4">
          <input class="form-control" name="name" placeholder="Book name" required />
        </div>
        <div class="col-md-3">
          <input class="form-control" name="author" placeholder="Author" required />
        </div>
        <div class="col-md-2">
          <input class="form-control" name="category" placeholder="Category (DBMS)" />
        </div>
        <div class="col-md-1">
          <input class="form-control" name="available" type="number" placeholder="Stock" required />
        </div>
        <div class="col-md-1">
          <input class="form-control" name="price" type="number" placeholder="Price" required />
        </div>
        <div class="col-md-1">
          <input class="form-control" name="discount" type="number" placeholder="%Off" />
        </div>

        <div class="col-12 d-grid mt-2">
          <button class="btn btn-brand btn-ripple py-2" type="submit" onclick="showToast('Added ✅','Book inserted into catalog')">
            <i class="bi bi-plus-lg me-2"></i> Add Book
          </button>
        </div>
      </form>

      <div class="glow"></div>
    </div>
  </div>

  <!-- List Books -->
  <div class="cardx">
    <div class="body">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
          <div class="title">Manage Books</div>
          <div class="sub">Update / Delete with premium UI</div>
        </div>
        <span class="badge-soft"><i class="bi bi-collection me-1"></i> <%= books.length %> items</span>
      </div>

      <div class="table-responsive">
        <table class="table table-dark table-borderless table-admin align-middle mb-0" style="--bs-table-bg: transparent;">
          <thead class="text-white-50">
            <tr>
              <th>ID</th>
              <th>Book</th>
              <th>Category</th>
              <th>Stock</th>
              <th>Price</th>
              <th>Off</th>
              <th style="width:190px;">Action</th>
            </tr>
          </thead>

          <tbody>
            <% books.forEach(b => { %>
              <tr>
                <td class="fw-bold"><%= b.id %></td>
                <td>
                  <div class="fw-bold"><%= b.name %></div>
                  <div class="text-white-50 small">by <%= b.author %></div>
                </td>
                <td><span class="badge-soft"><%= b.category || "General" %></span></td>
                <td><span class="badge-soft"><i class="bi bi-box-seam me-1"></i> <%= b.available %></span></td>
                <td class="fw-bold">₹<%= b.price %></td>
                <td><span class="badge-discount"><i class="bi bi-tag-fill text-warning"></i> <%= b.discount || 0 %>%</span></td>

                <td class="d-flex gap-2">
                  <a class="btn btn-ghost btn-sm btn-ripple" href="/admin/books/edit/<%= b.id %>">
                    <i class="bi bi-pencil-square me-1"></i> Edit
                  </a>

                  <form method="POST" action="/admin/books/delete/<%= b.id %>" onsubmit="return confirm('Delete this book?');">
                    <button class="btn btn-ghost btn-sm btn-ripple" type="submit">
                      <i class="bi bi-trash3 me-1 text-danger"></i> Delete
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>

        </table>
      </div>

      <div class="glow"></div>
    </div>
  </div>

</div>

<script src="/app.js"></script>
</body>
</html>
