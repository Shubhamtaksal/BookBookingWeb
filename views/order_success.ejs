<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Order Success • BookHub</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/common-footer.css">

  <style>
    :root{
      --bh-text:#0f172a;
      --bh-muted:#64748b;
      --bh-border:#e6eaf2;
      --bh-primary:#2563eb;
      --bh-success:#16a34a;
      --bh-shadow:0 18px 45px rgba(15,23,42,.10);
      --bh-shadow2:0 10px 28px rgba(15,23,42,.08);
      --bh-radius2:30px;
    }

    *{box-sizing:border-box}
    html,body{overflow-x:hidden}

    body{
      background:
        radial-gradient(circle at top left, rgba(37,99,235,.10), transparent 22%),
        radial-gradient(circle at top right, rgba(22,163,74,.08), transparent 18%),
        linear-gradient(180deg,#f8fbff,#eef4ff);
      color:var(--bh-text);
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    .page-wrap{
      min-height:70vh;
      padding:32px 0 48px;
      position:relative;
      z-index:1;
      display:flex;
      align-items:center;
    }

    .floating-shapes{
      position:fixed;
      inset:0;
      pointer-events:none;
      overflow:hidden;
      z-index:0;
    }

    .shape{
      position:absolute;
      border-radius:50%;
      filter:blur(10px);
      opacity:.22;
      animation:floatShape 12s ease-in-out infinite;
    }

    .shape.s1{
      width:180px;height:180px;
      background:rgba(37,99,235,.18);
      left:-40px;top:120px;
    }

    .shape.s2{
      width:220px;height:220px;
      background:rgba(22,163,74,.14);
      right:-60px;top:180px;
      animation-delay:2s;
    }

    .shape.s3{
      width:140px;height:140px;
      background:rgba(37,99,235,.12);
      left:20%;bottom:80px;
      animation-delay:4s;
    }

    @keyframes floatShape{
      0%,100%{transform:translateY(0) translateX(0)}
      50%{transform:translateY(-16px) translateX(8px)}
    }

    .success-card{
      background:linear-gradient(135deg, rgba(255,255,255,.97), rgba(255,255,255,.91));
      border:1px solid rgba(255,255,255,.8);
      border-radius:var(--bh-radius2);
      box-shadow:var(--bh-shadow);
      padding:34px;
      text-align:center;
      position:relative;
      overflow:hidden;
    }

    .success-card::before{
      content:"";
      position:absolute;
      width:280px;
      height:280px;
      right:-90px;
      top:-90px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(37,99,235,.12), transparent 70%);
    }

    .success-icon{
      width:96px;
      height:96px;
      margin:0 auto 18px;
      border-radius:28px;
      display:grid;
      place-items:center;
      background:linear-gradient(135deg,#16a34a,#22c55e);
      color:#fff;
      font-size:2.4rem;
      box-shadow:0 20px 36px rgba(22,163,74,.22);
    }

    .success-title{
      font-size:2rem;
      font-weight:900;
      margin-bottom:8px;
      line-height:1.1;
    }

    .success-sub{
      color:var(--bh-muted);
      font-size:1rem;
      max-width:650px;
      margin:0 auto 24px;
      line-height:1.7;
    }

    .info-grid{
      display:grid;
      grid-template-columns:repeat(3, minmax(0,1fr));
      gap:14px;
      margin:0 0 24px;
    }

    .info-box{
      background:#fff;
      border:1px solid var(--bh-border);
      border-radius:22px;
      padding:18px;
      box-shadow:var(--bh-shadow2);
      text-align:left;
    }

    .info-label{
      color:var(--bh-muted);
      font-size:.8rem;
      font-weight:800;
      margin-bottom:4px;
      text-transform:uppercase;
      letter-spacing:.3px;
    }

    .info-value{
      font-weight:900;
      color:#111827;
      word-break:break-word;
    }

    .status-pill{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:8px 12px;
      border-radius:999px;
      font-size:.78rem;
      font-weight:900;
      background:#dcfce7;
      color:#166534;
    }

    .action-row{
      display:flex;
      justify-content:center;
      gap:12px;
      flex-wrap:wrap;
    }

    .action-btn,
    .action-btn-outline{
      min-height:52px;
      border-radius:16px;
      padding:0 20px;
      font-weight:900;
      text-decoration:none;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      transition:.25s ease;
    }

    .action-btn{
      background:linear-gradient(135deg,#0f172a,#2563eb);
      color:#fff;
      box-shadow:0 18px 30px rgba(37,99,235,.20);
    }

    .action-btn:hover{
      color:#fff;
      transform:translateY(-2px);
    }

    .action-btn-outline{
      background:#fff;
      border:1px solid var(--bh-border);
      color:var(--bh-text);
    }

    .action-btn-outline:hover{
      color:var(--bh-primary);
      transform:translateY(-2px);
    }

    @media (max-width: 991px){
      .info-grid{
        grid-template-columns:1fr;
      }
    }

    @media (max-width: 767px){
      .success-card{
        padding:24px;
        border-radius:24px;
      }

      .success-title{
        font-size:1.7rem;
      }

      .action-row{
        flex-direction:column;
      }

      .action-btn,
      .action-btn-outline{
        width:100%;
      }
    }
  </style>
</head>
<body>

  <div class="floating-shapes">
    <span class="shape s1"></span>
    <span class="shape s2"></span>
    <span class="shape s3"></span>
  </div>

  <%- include('partials/navbar') %>

  <div class="container page-wrap">
    <div class="w-100 mx-auto" style="max-width: 980px;">
      <div class="success-card">
        <div class="success-icon">
          <i class="bi bi-check2-circle"></i>
        </div>

        <div class="success-title">Order Placed Successfully</div>
        <p class="success-sub">
          Your order has been confirmed successfully. You can track progress, review details, and continue shopping from your dashboard.
        </p>

        <div class="info-grid">
          <div class="info-box">
            <div class="info-label">Order ID</div>
            <div class="info-value">#<%= order.id %></div>
          </div>

          <div class="info-box">
            <div class="info-label">Payment Method</div>
            <div class="info-value"><%= order.payment_method || 'COD' %></div>
          </div>

          <div class="info-box">
            <div class="info-label">Current Status</div>
            <div class="info-value">
              <span class="status-pill"><%= order.status %></span>
            </div>
          </div>

          <div class="info-box">
            <div class="info-label">Total Amount</div>
            <div class="info-value">₹<%= order.total %></div>
          </div>

          <div class="info-box">
            <div class="info-label">Customer</div>
            <div class="info-value"><%= order.fullname || order.full_name || 'Customer' %></div>
          </div>

          <div class="info-box">
            <div class="info-label">Date</div>
            <div class="info-value"><%= new Date(order.created_at).toLocaleString() %></div>
          </div>
        </div>

        <div class="action-row">
          <a href="/my-orders" class="action-btn">
            <i class="bi bi-bag-check"></i> View My Orders
          </a>

          <a href="/books" class="action-btn-outline">
            <i class="bi bi-book"></i> Continue Shopping
          </a>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
</body>
</html>