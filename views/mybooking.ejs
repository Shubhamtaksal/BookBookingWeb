<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>My Bookings • BookHub</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css" />
</head>

<body class="page page-enter">


<div class="container-xxl py-4">

  <nav class="navbar nav-glass px-3 py-2 mb-4">
    <div class="d-flex align-items-center gap-2">
      <a href="/" class="brand-badge">B</a>
      <div class="fw-bold">BookHub</div>
      <span class="badge-soft ms-2">My Bookings</span>
    </div>
    <div class="ms-auto d-flex gap-2">
      <a class="btn btn-ghost btn-sm btn-ripple" href="/books"><i class="bi bi-grid"></i> Books</a>
      <a class="btn btn-ghost btn-sm btn-ripple" href="/checkout"><i class="bi bi-bag-check"></i> Checkout</a>
    </div>
  </nav>

  <div class="cardx">
    <div class="body">
      <div class="d-flex align-items-center justify-content-between mb-2">
        <div>
          <div class="title">Booking History</div>
          <div class="sub">Saved locally (Demo). Next step: Oracle DB.</div>
        </div>
        <button id="clearHistory" class="btn btn-ghost btn-sm btn-ripple">
          <i class="bi bi-trash3"></i> Clear
        </button>
      </div>

      <div id="historyBox" class="mt-3"></div>
    </div>
  </div>

</div>

<script>
  const KEY = "bookhub_bookings_v1";
  const data = JSON.parse(localStorage.getItem(KEY) || "[]");
  const box = document.getElementById("historyBox");

  function render(){
    const items = JSON.parse(localStorage.getItem(KEY) || "[]");
    if(!items.length){
      box.innerHTML = `
        <div class="text-white-50">
          No bookings yet. Go to <a href="/books">Books</a> and checkout.
        </div>`;
      return;
    }

    box.innerHTML = items.map((b, i) => `
      <div class="cardx mb-3">
        <div class="body">
          <div class="d-flex justify-content-between">
            <div class="fw-bold">Booking #${items.length - i}</div>
            <div class="text-white-50 small">${new Date(b.time).toLocaleString()}</div>
          </div>
          <div class="text-white-50 small mb-2">
            Items: ${b.items.length} • Total: ₹${b.total}
          </div>

          ${b.items.map(x => `
            <div class="d-flex align-items-center gap-2 mb-2">
              <img src="${x.image}" style="width:42px;height:42px;border-radius:10px;object-fit:cover;border:1px solid rgba(255,255,255,.12)">
              <div class="flex-grow-1">
                <div class="fw-semibold">${x.name}</div>
                <div class="text-white-50 small">₹${x.price} × ${x.qty}</div>
              </div>
              <div class="fw-bold">₹${x.price * x.qty}</div>
            </div>
          `).join("")}

        </div>
      </div>
    `).join("");
  }

  render();

  document.getElementById("clearHistory").addEventListener("click", () => {
    localStorage.removeItem(KEY);
    render();
  });

  window.addEventListener("load", () => document.body.classList.remove("page-enter"));
</script>
</body>
</html>
