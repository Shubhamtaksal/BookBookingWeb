<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>My Orders • BookHub</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/common-footer.css">

  <style>
    :root{
      --bh-bg:#f6f8fc;
      --bh-card:#ffffff;
      --bh-text:#0f172a;
      --bh-muted:#64748b;
      --bh-border:#e6eaf2;
      --bh-primary:#2563eb;
      --bh-primary2:#0ea5e9;
      --bh-success:#16a34a;
      --bh-warning:#d97706;
      --bh-danger:#ef4444;
      --bh-shadow:0 18px 45px rgba(15,23,42,.10);
      --bh-shadow2:0 10px 28px rgba(15,23,42,.08);
      --bh-radius:24px;
      --bh-radius2:30px;
    }

    *{box-sizing:border-box}
    html,body{overflow-x:hidden}

    body{
      background:
        radial-gradient(circle at top left, rgba(37,99,235,.10), transparent 22%),
        radial-gradient(circle at top right, rgba(14,165,233,.08), transparent 18%),
        linear-gradient(180deg,#f8fbff,#eef4ff);
      color:var(--bh-text);
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    .page-wrap{
      padding:26px 0 48px;
      position:relative;
      z-index:1;
    }

    .floating-shapes{
      position:fixed;
      inset:0;
      pointer-events:none;
      overflow:hidden;
      z-index:0;
    }

    .shape{
      position:absolute;
      border-radius:50%;
      filter:blur(10px);
      opacity:.22;
      animation:floatShape 12s ease-in-out infinite;
    }

    .shape.s1{
      width:180px;height:180px;
      background:rgba(37,99,235,.18);
      left:-40px;top:120px;
    }

    .shape.s2{
      width:220px;height:220px;
      background:rgba(14,165,233,.15);
      right:-60px;top:180px;
      animation-delay:2s;
    }

    .shape.s3{
      width:140px;height:140px;
      background:rgba(37,99,235,.12);
      left:20%;bottom:80px;
      animation-delay:4s;
    }

    @keyframes floatShape{
      0%,100%{transform:translateY(0) translateX(0)}
      50%{transform:translateY(-16px) translateX(8px)}
    }

    .hero-card,
    .orders-card,
    .empty-card{
      background:linear-gradient(135deg, rgba(255,255,255,.96), rgba(255,255,255,.90));
      border:1px solid rgba(255,255,255,.78);
      border-radius:var(--bh-radius2);
      box-shadow:var(--bh-shadow);
    }

    .hero-card{
      padding:24px;
      margin-bottom:22px;
      position:relative;
      overflow:hidden;
    }

    .hero-card::before{
      content:"";
      position:absolute;
      width:280px;
      height:280px;
      right:-90px;
      top:-90px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(37,99,235,.14), transparent 65%);
    }

    .hero-title{
      font-size:2.15rem;
      font-weight:900;
      line-height:1.1;
      margin-bottom:6px;
    }

    .hero-sub{
      color:var(--bh-muted);
      margin-bottom:0;
    }

    .hero-actions{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
    }

    .hero-actions .btn{
      border-radius:14px;
      font-weight:900;
      min-height:46px;
      padding:0 16px;
    }

    .success-alert{
      border-radius:18px;
      font-weight:800;
      box-shadow:var(--bh-shadow2);
      margin-bottom:18px;
    }

    .orders-card{
      padding:22px;
    }

    .order-item{
      display:grid;
      grid-template-columns:1.2fr .8fr .7fr .7fr .7fr;
      gap:16px;
      align-items:center;
      padding:18px 0;
      border-bottom:1px solid #edf2f9;
      transition:.25s ease;
    }

    .order-item:hover{
      transform:translateY(-2px);
    }

    .order-item:last-child{
      border-bottom:none;
    }

    .order-main{
      min-width:0;
    }

    .order-id{
      font-size:1rem;
      font-weight:900;
      margin-bottom:4px;
    }

    .order-date{
      color:var(--bh-muted);
      font-size:.9rem;
      font-weight:700;
    }

    .order-meta-title{
      color:var(--bh-muted);
      font-size:.8rem;
      font-weight:800;
      margin-bottom:4px;
      text-transform:uppercase;
      letter-spacing:.3px;
    }

    .order-meta-value{
      font-weight:900;
      color:#111827;
      word-break:break-word;
    }

    .status-pill{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:8px 12px;
      border-radius:999px;
      font-size:.78rem;
      font-weight:900;
      min-width:120px;
    }

    .st-placed{background:#dbeafe;color:#1d4ed8}
    .st-paid{background:#dcfce7;color:#166534}
    .st-shipped{background:#ede9fe;color:#6d28d9}
    .st-out{background:#fef3c7;color:#b45309}
    .st-delivered{background:#dcfce7;color:#166534}
    .st-cancelled{background:#fee2e2;color:#b91c1c}
    .st-default{background:#e5e7eb;color:#475569}

    .order-total{
      font-size:1.12rem;
      font-weight:900;
      color:var(--bh-primary);
    }

    .view-btn{
      border-radius:14px;
      font-weight:900;
      min-height:44px;
      padding:0 14px;
      white-space:nowrap;
    }

    .empty-card{
      padding:42px 24px;
      text-align:center;
    }

    .empty-icon{
      width:88px;
      height:88px;
      margin:0 auto 16px;
      border-radius:24px;
      display:grid;
      place-items:center;
      background:#eef4ff;
      color:var(--bh-primary);
      font-size:2rem;
    }

    .empty-card h3{
      font-size:1.6rem;
      font-weight:900;
      margin-bottom:8px;
    }

    .empty-card p{
      color:var(--bh-muted);
      margin-bottom:18px;
    }

    .empty-card .btn{
      border-radius:16px;
      font-weight:900;
      min-height:50px;
      padding:0 18px;
    }

    @media (max-width: 991px){
      .order-item{
        grid-template-columns:1fr 1fr;
        gap:14px;
      }
    }

    @media (max-width: 767px){
      .hero-card,
      .orders-card,
      .empty-card{
        border-radius:24px;
      }

      .hero-title{
        font-size:1.8rem;
      }

      .order-item{
        grid-template-columns:1fr;
      }

      .hero-actions{
        width:100%;
      }

      .hero-actions .btn{
        flex:1;
      }
    }
  </style>
</head>
<body>

  <div class="floating-shapes">
    <span class="shape s1"></span>
    <span class="shape s2"></span>
    <span class="shape s3"></span>
  </div>

  <%- include('partials/navbar') %>

  <div class="container page-wrap">
    <div class="hero-card d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <div class="hero-title">My Orders</div>
        <p class="hero-sub">Track your purchases, payment state, and delivery progress from one premium dashboard.</p>
      </div>

      <div class="hero-actions">
        <a href="/books" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-left"></i> Continue Shopping
        </a>
        <a href="/cart" class="btn btn-primary">
          <i class="bi bi-cart3"></i> Open Cart
        </a>
      </div>
    </div>

    <% if (placed) { %>
      <div class="alert alert-success success-alert">
        <i class="bi bi-check-circle-fill"></i> Your order was placed successfully.
      </div>
    <% } %>

    <% if (!orders.length) { %>
      <div class="empty-card">
        <div class="empty-icon">
          <i class="bi bi-bag-x"></i>
        </div>
        <h3>No orders yet</h3>
        <p>Once you place an order, it will appear here with payment and delivery status.</p>
        <a href="/books" class="btn btn-primary">
          <i class="bi bi-book"></i> Browse Books
        </a>
      </div>
    <% } else { %>
      <div class="orders-card">
        <% orders.forEach((order) => { 
          let statusClass = "st-default";
          if (order.status === "PLACED") statusClass = "st-placed";
          else if (order.status === "PAID") statusClass = "st-paid";
          else if (order.status === "SHIPPED") statusClass = "st-shipped";
          else if (order.status === "OUT_FOR_DELIVERY") statusClass = "st-out";
          else if (order.status === "DELIVERED") statusClass = "st-delivered";
          else if (order.status === "CANCELLED") statusClass = "st-cancelled";
        %>
          <div class="order-item">
            <div class="order-main">
              <div class="order-id">Order #<%= order.id %></div>
              <div class="order-date">
                <i class="bi bi-clock"></i>
                <%= new Date(order.created_at).toLocaleString() %>
              </div>
            </div>

            <div>
              <div class="order-meta-title">Payment</div>
              <div class="order-meta-value"><%= order.payment_method || 'COD' %></div>
            </div>

            <div>
              <div class="order-meta-title">Status</div>
              <div class="status-pill <%= statusClass %>"><%= order.status %></div>
            </div>

            <div>
              <div class="order-meta-title">Total</div>
              <div class="order-total">₹<%= order.total %></div>
            </div>

            <div>
              <a href="/my-orders/<%= order.id %>" class="btn btn-outline-primary view-btn">
                <i class="bi bi-eye"></i> View
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <%- include('partials/footer') %>
</body>
</html>