<%- include("../partials/head", { title: "Reports • Admin" }) %>

<div class="container-xxl py-4">
  <%- include("../partials/navbar", { badge: "Reports", cartCount, isAdmin: true }) %>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <div class="title mb-0"><i class="bi bi-file-earmark-spreadsheet me-2"></i>Reports</div>

    <div class="d-flex gap-2">
      <a class="btn btn-warning" href="/admin/reports/orders.csv">
        <i class="bi bi-download"></i> Export Orders CSV
      </a>
      <a class="btn btn-outline-light" href="/admin">
        <i class="bi bi-arrow-left"></i> Back
      </a>
    </div>
  </div>

  <div class="cardx">
    <div class="body">
      <div class="sub mb-2">Recent Orders Preview</div>

      <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0">
          <thead>
            <tr>
              <th>#</th>
              <th>User</th>
              <th>Email</th>
              <th>Total</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(o => { %>
              <tr>
                <td class="fw-bold"><%= o.id %></td>
                <td><%= o.fullname %></td>
                <td><%= o.email %></td>
                <td>₹<%= Number(o.total).toFixed(0) %></td>
                <td><span class="badge bg-secondary"><%= o.status %></span></td>
                <td class="small text-white-50"><%= new Date(o.created_at).toLocaleString() %></td>
              </tr>
            <% }) %>

            <% if (!orders || orders.length===0) { %>
              <tr><td colspan="6" class="text-center text-white-50">No orders to show.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <div class="small text-white-50 mt-3">
        ✅ Export gives CSV (Excel-friendly) for submission / documentation.
      </div>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
