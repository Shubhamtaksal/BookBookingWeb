<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= mode === 'new' ? 'Add Book' : 'Edit Book' %> • Admin</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <style>
    :root{
      --bg:#f4f8ff;
      --card:#ffffff;
      --text:#0f172a;
      --muted:#64748b;
      --border:#e6edf7;
      --primary:#2563eb;
      --shadow:0 18px 45px rgba(15,23,42,.08);
      --radius:26px;
    }

    body{
      background:
        radial-gradient(circle at top left, rgba(37,99,235,.08), transparent 22%),
        radial-gradient(circle at top right, rgba(96,165,250,.08), transparent 18%),
        linear-gradient(180deg,#f8fbff,#eef4ff);
      color:var(--text);
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    .page-wrap{
      padding:30px 0 48px;
    }

    .hero-card,
    .form-card,
    .preview-card{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
    }

    .hero-card{
      padding:24px;
      margin-bottom:20px;
    }

    .hero-title{
      font-size:2rem;
      font-weight:900;
      margin-bottom:6px;
    }

    .hero-sub{
      color:var(--muted);
      margin-bottom:0;
    }

    .top-actions .btn{
      border-radius:12px;
      font-weight:800;
      padding:10px 14px;
    }

    .form-card{
      padding:24px;
    }

    .preview-card{
      padding:20px;
      position:sticky;
      top:20px;
    }

    .section-title{
      font-size:1.18rem;
      font-weight:900;
      margin-bottom:6px;
    }

    .section-sub{
      color:var(--muted);
      font-size:.94rem;
      margin-bottom:18px;
    }

    .soft-label{
      font-weight:800;
      margin-bottom:8px;
      color:#111827;
    }

    .soft-input,
    .soft-select{
      min-height:54px;
      border-radius:16px;
      border:1px solid #dbe3ef;
      padding-left:14px;
      padding-right:14px;
    }

    .soft-input:focus,
    .soft-select:focus{
      border-color:#60a5fa;
      box-shadow:none;
    }

    .soft-file{
      min-height:54px;
      border-radius:16px;
      border:1px solid #dbe3ef;
      padding:12px 14px;
    }

    .thumb-wrap{
      display:flex;
      align-items:center;
      justify-content:center;
      padding:18px;
      border-radius:20px;
      background:linear-gradient(180deg,#eff6ff,#ffffff);
      border:1px dashed #cbd5e1;
      margin-bottom:16px;
    }

    .thumb{
      width:160px;
      height:220px;
      object-fit:cover;
      border-radius:16px;
      background:#fff;
      border:1px solid rgba(0,0,0,.08);
      box-shadow:0 18px 32px rgba(15,23,42,.12);
    }

    .preview-chip{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      background:#eef4ff;
      color:#2563eb;
      font-size:.82rem;
      font-weight:800;
      margin-bottom:12px;
    }

    .preview-title{
      font-size:1.2rem;
      font-weight:900;
      margin-bottom:4px;
      line-height:1.3;
    }

    .preview-author{
      color:var(--muted);
      margin-bottom:12px;
      font-size:.95rem;
    }

    .price-row{
      display:flex;
      align-items:center;
      gap:10px;
      flex-wrap:wrap;
      margin-bottom:14px;
    }

    .price-final{
      font-size:1.5rem;
      font-weight:900;
      color:#111827;
    }

    .price-old{
      color:#9ca3af;
      text-decoration:line-through;
      font-weight:700;
    }

    .stock-pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      background:#ecfdf3;
      color:#166534;
      font-size:.84rem;
      font-weight:800;
      margin-bottom:16px;
    }

    .save-btn{
      min-height:54px;
      border:none;
      border-radius:16px;
      background:linear-gradient(135deg,#0f172a,#2563eb);
      color:#fff;
      font-weight:900;
      padding:0 22px;
    }

    .alert{
      border-radius:18px;
    }
  </style>
</head>
<body>
  <div class="container page-wrap">
    <div class="hero-card d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <div class="hero-title"><%= mode === 'new' ? 'Add New Book' : 'Edit Book' %></div>
        <p class="hero-sub">Manage book details, pricing, stock, image, category, and listing status.</p>
      </div>

      <div class="top-actions d-flex gap-2 flex-wrap">
        <a href="/admin/books" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-left"></i> Back to Books
        </a>
      </div>
    </div>

    <% if (errors && errors.length) { %>
      <div class="alert alert-danger">
        <% errors.forEach((e) => { %>
          <div><%= e.msg %></div>
        <% }) %>
      </div>
    <% } %>

    <div class="row g-4">
      <div class="col-lg-8">
        <div class="form-card">
          <div class="section-title">Book Information</div>
          <div class="section-sub">Fill all required details for this book record.</div>

          <form method="POST" enctype="multipart/form-data" action="<%= mode === 'new' ? '/admin/books/new' : '/admin/books/' + book.id + '/edit' %>">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="soft-label">Book Name</label>
                <input type="text" name="name" class="form-control soft-input" value="<%= book?.name || '' %>" required>
              </div>

              <div class="col-md-6">
                <label class="soft-label">Author Name</label>
                <input type="text" name="author" class="form-control soft-input" value="<%= book?.author || '' %>" required>
              </div>

              <div class="col-md-6">
                <label class="soft-label">Category</label>
                <select name="category_id" class="form-select soft-select" required>
                  <option value="">Select category</option>
                  <% categories.forEach((c) => { %>
                    <option value="<%= c.id %>" <%= Number(book?.category_id) === Number(c.id) ? 'selected' : '' %>><%= c.name %></option>
                  <% }) %>
                </select>
              </div>

              <div class="col-md-6">
                <label class="soft-label">Available Stock</label>
                <input type="number" name="available" class="form-control soft-input" value="<%= book?.available ?? 0 %>" required>
              </div>

              <div class="col-md-4">
                <label class="soft-label">Price</label>
                <input type="number" name="price" class="form-control soft-input" value="<%= book?.price ?? 0 %>" required>
              </div>

              <div class="col-md-4">
                <label class="soft-label">Discount (%)</label>
                <input type="number" name="discount" class="form-control soft-input" value="<%= book?.discount ?? 0 %>" required>
              </div>

              <% if (mode === 'edit') { %>
              <div class="col-md-4">
                <label class="soft-label">Status</label>
                <select name="is_active" class="form-select soft-select">
                  <option value="1" <%= Number(book?.is_active) === 1 ? 'selected' : '' %>>Active</option>
                  <option value="0" <%= Number(book?.is_active) === 0 ? 'selected' : '' %>>Inactive</option>
                </select>
              </div>
              <% } %>

              <div class="col-12">
                <label class="soft-label">Book Cover Image</label>
                <input type="file" name="image" class="form-control soft-file">
              </div>
            </div>

            <button class="save-btn mt-4">
              <i class="bi bi-check-circle"></i>
              <%= mode === 'new' ? 'Save New Book' : 'Update Book' %>
            </button>
          </form>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="preview-card">
          <div class="section-title">Live Preview</div>
          <div class="section-sub">How this book card looks in your bookstore.</div>

          <div class="thumb-wrap">
            <img
              src="<%= book?.image || '/uploads/default.png' %>"
              class="thumb"
              onerror="this.onerror=null;this.src='/uploads/default.png'"
            >
          </div>

          <div class="preview-chip">
            <i class="bi bi-bookmark-star"></i>
            <%= categories.find(c => Number(c.id) === Number(book?.category_id))?.name || 'Category' %>
          </div>

          <div class="preview-title"><%= book?.name || 'Book Title Preview' %></div>
          <div class="preview-author"><i class="bi bi-person"></i> <%= book?.author || 'Author Name' %></div>

          <%
            const p = Number(book?.price || 0);
            const d = Number(book?.discount || 0);
            const finalPrice = Math.max(0, p - Math.round((p * d) / 100));
          %>

          <div class="price-row">
            <div class="price-final">₹<%= finalPrice %></div>
            <% if (p > 0 && d > 0) { %>
              <div class="price-old">₹<%= p %></div>
            <% } %>
          </div>

          <div class="stock-pill">
            <i class="bi bi-box-seam"></i> Stock: <%= book?.available ?? 0 %>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>