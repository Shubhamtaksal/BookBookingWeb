<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Manage Books • Admin</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <style>
    :root{
      --bg:#f4f8ff;
      --card:#ffffff;
      --text:#0f172a;
      --muted:#64748b;
      --border:#e6edf7;
      --primary:#2563eb;
      --shadow:0 18px 45px rgba(15,23,42,.08);
    }

    *{ box-sizing:border-box; }

    body{
      background:
        radial-gradient(circle at top left, rgba(37,99,235,.08), transparent 22%),
        linear-gradient(180deg,#f8fbff,#eef4ff);
      color:var(--text);
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
      position:relative;
      overflow-x:hidden;
    }

    /* FLOATING BOOKS BACKGROUND */
    .floating-books{
      position:fixed;
      inset:0;
      pointer-events:none;
      overflow:hidden;
      z-index:0;
    }

    .float-book{
      position:absolute;
      color:rgba(37,99,235,.10);
      filter:blur(.2px);
      animation:floatBook 14s ease-in-out infinite;
      user-select:none;
    }

    .float-book i{
      font-size:58px;
    }

    .float-book.b1{
      top:10%;
      left:6%;
      animation-duration:12s;
    }

    .float-book.b2{
      top:18%;
      right:10%;
      animation-duration:15s;
      animation-delay:1s;
    }

    .float-book.b3{
      bottom:18%;
      left:12%;
      animation-duration:13s;
      animation-delay:2s;
    }

    .float-book.b4{
      bottom:10%;
      right:8%;
      animation-duration:16s;
      animation-delay:3s;
    }

    .float-book.b5{
      top:48%;
      left:48%;
      animation-duration:14s;
      animation-delay:1.5s;
    }

    @keyframes floatBook{
      0%,100%{
        transform:translateY(0) rotate(0deg) scale(1);
        opacity:.45;
      }
      25%{
        transform:translateY(-18px) rotate(4deg) scale(1.04);
        opacity:.7;
      }
      50%{
        transform:translateY(10px) rotate(-3deg) scale(.98);
        opacity:.5;
      }
      75%{
        transform:translateY(-12px) rotate(2deg) scale(1.02);
        opacity:.68;
      }
    }

    .page-wrap{
      position:relative;
      z-index:1;
      padding:30px 0 48px;
    }

    .hero-card,
    .table-card{
      background:rgba(255,255,255,.92);
      border:1px solid var(--border);
      border-radius:26px;
      box-shadow:var(--shadow);
      backdrop-filter:blur(10px);
      -webkit-backdrop-filter:blur(10px);
    }

    .hero-card{
      padding:24px;
      margin-bottom:20px;
    }

    .hero-title{
      font-size:2rem;
      font-weight:900;
      margin-bottom:6px;
    }

    .hero-sub{
      color:var(--muted);
      margin-bottom:0;
    }

    .top-actions .btn{
      border-radius:12px;
      font-weight:800;
      padding:10px 14px;
    }

    .table-card{
      padding:18px;
    }

    .table > :not(caption) > * > *{
      padding:16px 12px;
      border-bottom-color:#edf2f9;
      vertical-align:middle;
      background:transparent;
    }

    .table tbody tr{
      transition:.25s ease;
    }

    .table tbody tr:hover{
      transform:translateY(-2px);
      box-shadow:0 10px 24px rgba(15,23,42,.05);
    }

    .book-thumb{
      width:58px;
      height:76px;
      object-fit:cover;
      border-radius:12px;
      border:1px solid rgba(0,0,0,.06);
      background:#fff;
      box-shadow:0 8px 18px rgba(15,23,42,.06);
      transition:.3s ease;
    }

    .table tbody tr:hover .book-thumb{
      transform:scale(1.05) rotate(-2deg);
      box-shadow:0 16px 28px rgba(15,23,42,.12);
    }

    .book-title{
      font-weight:800;
      color:#111827;
    }

    .book-author{
      color:var(--muted);
      font-size:.92rem;
      margin-top:2px;
    }

    .cat-pill{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border-radius:999px;
      padding:7px 12px;
      font-size:.78rem;
      font-weight:800;
      background:#eef4ff;
      color:#2563eb;
      white-space:nowrap;
    }

    .status-pill{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border-radius:999px;
      padding:7px 12px;
      font-size:.78rem;
      font-weight:800;
      white-space:nowrap;
    }

    .st-active{
      background:#dcfce7;
      color:#166534;
    }

    .st-inactive{
      background:#e5e7eb;
      color:#475569;
    }

    .price-text{
      font-weight:900;
      color:#111827;
    }

    .stock-badge{
      display:inline-flex;
      align-items:center;
      gap:6px;
      font-weight:800;
      color:#334155;
    }

    .mini-btn{
      border-radius:12px;
      font-weight:800;
      padding:8px 12px;
      white-space:nowrap;
      transition:.25s ease;
    }

    .mini-btn:hover{
      transform:translateY(-2px);
    }

    .action-wrap{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
    }

    @media (max-width: 768px){
      .hero-title{
        font-size:1.6rem;
      }
    }
  </style>
</head>
<body>

  <div class="floating-books">
    <span class="float-book b1"><i class="bi bi-book"></i></span>
    <span class="float-book b2"><i class="bi bi-book-half"></i></span>
    <span class="float-book b3"><i class="bi bi-journal-bookmark"></i></span>
    <span class="float-book b4"><i class="bi bi-book"></i></span>
    <span class="float-book b5"><i class="bi bi-journal-richtext"></i></span>
  </div>

  <div class="container page-wrap">
    <div class="hero-card d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <div class="hero-title">Manage Books</div>
        <p class="hero-sub">Add, edit, delete, and control your complete bookstore inventory.</p>
      </div>

      <div class="top-actions d-flex gap-2 flex-wrap">
        <a href="/admin" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-left"></i> Dashboard
        </a>
        <a href="/admin/books/new" class="btn btn-primary">
          <i class="bi bi-plus-circle"></i> Add Book
        </a>
      </div>
    </div>

    <div class="table-card">
      <div class="table-responsive">
        <table class="table align-middle">
          <thead>
            <tr>
              <th>ID</th>
              <th>Cover</th>
              <th>Book</th>
              <th>Category</th>
              <th>Price</th>
              <th>Stock</th>
              <th>Status</th>
              <th style="width:180px">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% books.forEach((b) => { %>
              <tr>
                <td class="fw-bold">#<%= b.id %></td>

                <td>
                  <img
                    src="<%= b.image || '/uploads/default.png' %>"
                    class="book-thumb"
                    onerror="this.onerror=null;this.src='/uploads/default.png'"
                    alt="<%= b.name %>"
                  >
                </td>

                <td>
                  <div class="book-title"><%= b.name %></div>
                  <div class="book-author"><%= b.author %></div>
                </td>

                <td>
                  <span class="cat-pill"><%= b.category_name || 'Uncategorized' %></span>
                </td>

                <td class="price-text">₹<%= b.price %></td>

                <td>
                  <span class="stock-badge">
                    <i class="bi bi-box"></i> <%= b.available %>
                  </span>
                </td>

                <td>
                  <% if (Number(b.is_active) === 1) { %>
                    <span class="status-pill st-active">Active</span>
                  <% } else { %>
                    <span class="status-pill st-inactive">Inactive</span>
                  <% } %>
                </td>

                <td>
                  <div class="action-wrap">
                    <a href="/admin/books/<%= b.id %>/edit" class="btn btn-outline-primary mini-btn">
                      <i class="bi bi-pencil-square"></i> Edit
                    </a>

                    <form action="/admin/books/<%= b.id %>/delete" method="POST" style="display:inline">
                      <button class="btn btn-outline-danger mini-btn" onclick="return confirm('Delete this book?')">
                        <i class="bi bi-trash"></i> Delete
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</body>
</html>