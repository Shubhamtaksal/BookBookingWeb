<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin Order Details • BookHub</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <style>
    :root{
      --bg:#f4f8ff;
      --card:#ffffff;
      --text:#0f172a;
      --muted:#64748b;
      --border:#e6edf7;
      --primary:#2563eb;
      --primary2:#0ea5e9;
      --success:#16a34a;
      --warning:#d97706;
      --danger:#ef4444;
      --shadow:0 18px 45px rgba(15,23,42,.08);
      --shadow2:0 10px 28px rgba(15,23,42,.06);
    }

    *{box-sizing:border-box}
    html,body{overflow-x:hidden}

    body{
      background:
        radial-gradient(circle at top left, rgba(37,99,235,.08), transparent 22%),
        linear-gradient(180deg,#f8fbff,#eef4ff);
      color:var(--text);
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
      position:relative;
    }

    .floating-orders{
      position:fixed;
      inset:0;
      pointer-events:none;
      overflow:hidden;
      z-index:0;
    }

    .float-icon{
      position:absolute;
      color:rgba(37,99,235,.10);
      animation:floatIcon 14s ease-in-out infinite;
      user-select:none;
    }

    .float-icon i{font-size:56px}
    .float-icon.i1{top:10%;left:6%;animation-duration:12s}
    .float-icon.i2{top:20%;right:10%;animation-duration:15s;animation-delay:1s}
    .float-icon.i3{bottom:18%;left:14%;animation-duration:13s;animation-delay:2s}
    .float-icon.i4{bottom:10%;right:9%;animation-duration:16s;animation-delay:3s}

    @keyframes floatIcon{
      0%,100%{transform:translateY(0) rotate(0deg) scale(1);opacity:.45}
      25%{transform:translateY(-16px) rotate(4deg) scale(1.04);opacity:.7}
      50%{transform:translateY(10px) rotate(-3deg) scale(.98);opacity:.52}
      75%{transform:translateY(-12px) rotate(2deg) scale(1.02);opacity:.68}
    }

    .page-wrap{
      position:relative;
      z-index:1;
      padding:30px 0 48px;
    }

    .hero-card,
    .glass-card{
      background:rgba(255,255,255,.92);
      border:1px solid var(--border);
      border-radius:28px;
      box-shadow:var(--shadow);
      backdrop-filter:blur(10px);
      -webkit-backdrop-filter:blur(10px);
    }

    .hero-card{
      padding:24px;
      margin-bottom:20px;
      position:relative;
      overflow:hidden;
    }

    .hero-card::before{
      content:"";
      position:absolute;
      width:260px;
      height:260px;
      right:-90px;
      top:-90px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(37,99,235,.14), transparent 70%);
    }

    .hero-title{
      font-size:2rem;
      font-weight:900;
      margin-bottom:6px;
      line-height:1.1;
    }

    .hero-sub{
      color:var(--muted);
      margin-bottom:0;
      max-width:650px;
    }

    .top-actions{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
    }

    .top-actions .btn{
      border-radius:14px;
      font-weight:900;
      min-height:46px;
      padding:0 16px;
    }

    .glass-card{
      padding:22px;
      margin-bottom:20px;
    }

    .section-title{
      font-size:1.22rem;
      font-weight:900;
      margin-bottom:6px;
    }

    .section-sub{
      color:var(--muted);
      margin-bottom:18px;
      font-size:.93rem;
    }

    .top-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:16px;
    }

    .info-box{
      background:#fff;
      border:1px solid var(--border);
      border-radius:22px;
      padding:18px;
      box-shadow:var(--shadow2);
      height:100%;
    }

    .info-label{
      color:var(--muted);
      font-size:.8rem;
      font-weight:800;
      margin-bottom:4px;
      text-transform:uppercase;
      letter-spacing:.3px;
    }

    .info-value{
      color:#111827;
      font-weight:900;
      margin-bottom:12px;
      word-break:break-word;
    }

    .status-pill{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:8px 12px;
      border-radius:999px;
      font-size:.78rem;
      font-weight:900;
      min-width:120px;
    }

    .st-placed{background:#dbeafe;color:#1d4ed8}
    .st-paid{background:#dcfce7;color:#166534}
    .st-shipped{background:#ede9fe;color:#6d28d9}
    .st-out{background:#fef3c7;color:#b45309}
    .st-delivered{background:#dcfce7;color:#166534}
    .st-cancelled{background:#fee2e2;color:#b91c1c}
    .st-default{background:#e5e7eb;color:#475569}

    .track-wrap{
      display:grid;
      grid-template-columns:repeat(5,1fr);
      gap:12px;
    }

    .track-step{
      text-align:center;
      padding:14px 10px;
      border-radius:18px;
      border:1px solid var(--border);
      background:#fff;
      box-shadow:var(--shadow2);
      font-weight:800;
      color:#64748b;
      min-height:72px;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .track-step.active{
      background:#eef4ff;
      color:var(--primary);
      border-color:#cfe0ff;
    }

    .track-step.done{
      background:#dcfce7;
      color:#166534;
      border-color:#bbf7d0;
    }

    .order-book{
      display:grid;
      grid-template-columns:92px 1fr 100px;
      gap:16px;
      align-items:start;
      padding:16px;
      border:1px solid var(--border);
      border-radius:22px;
      background:#fff;
      box-shadow:var(--shadow2);
      margin-bottom:14px;
    }

    .order-book:last-child{
      margin-bottom:0;
    }

    .book-img-wrap{
      display:flex;
      justify-content:center;
      align-items:center;
      background:linear-gradient(180deg,#f8fbff,#ffffff);
      border:1px solid var(--border);
      border-radius:18px;
      padding:8px;
      min-height:120px;
    }

    .book-img{
      width:72px;
      height:98px;
      object-fit:cover;
      border-radius:12px;
      background:#fff;
      border:1px solid rgba(0,0,0,.05);
      box-shadow:0 10px 20px rgba(15,23,42,.10);
    }

    .book-title{
      font-size:1.03rem;
      font-weight:900;
      margin-bottom:4px;
      line-height:1.35;
    }

    .book-author{
      color:var(--muted);
      font-size:.92rem;
      margin-bottom:8px;
    }

    .book-meta{
      display:flex;
      gap:14px;
      flex-wrap:wrap;
      color:#334155;
      font-size:.84rem;
      font-weight:700;
    }

    .book-price{
      text-align:right;
      font-size:1.15rem;
      font-weight:900;
      color:var(--primary);
    }

    .summary-card{
      background:#fff;
      border:1px solid var(--border);
      border-radius:22px;
      padding:18px;
      box-shadow:var(--shadow2);
      margin-bottom:16px;
    }

    .summary-row{
      display:flex;
      justify-content:space-between;
      gap:10px;
      margin-bottom:12px;
      color:#334155;
      font-weight:700;
    }

    .summary-total{
      display:flex;
      justify-content:space-between;
      gap:10px;
      border-top:1px solid #e6edf7;
      padding-top:14px;
      margin-top:14px;
      font-size:1.2rem;
      font-weight:900;
      color:#111827;
    }

    .address-box{
      background:#fff;
      border:1px solid var(--border);
      border-radius:22px;
      padding:18px;
      box-shadow:var(--shadow2);
    }

    .address-box strong{
      display:block;
      margin-bottom:6px;
      font-size:1rem;
    }

    .address-box p{
      margin:0;
      color:#475569;
      line-height:1.7;
      word-break:break-word;
    }

    @media (max-width: 991px){
      .top-grid{
        grid-template-columns:1fr;
      }

      .track-wrap{
        grid-template-columns:1fr 1fr;
      }

      .order-book{
        grid-template-columns:92px 1fr;
      }

      .book-price{
        grid-column:1 / -1;
        text-align:left;
      }
    }

    @media (max-width: 767px){
      .hero-card,
      .glass-card{
        border-radius:22px;
      }

      .hero-title{
        font-size:1.7rem;
      }

      .track-wrap{
        grid-template-columns:1fr;
      }

      .order-book{
        grid-template-columns:1fr;
      }

      .book-img-wrap{
        max-width:160px;
      }
    }
  </style>
</head>
<body>

  <div class="floating-orders">
    <span class="float-icon i1"><i class="bi bi-bag-check"></i></span>
    <span class="float-icon i2"><i class="bi bi-receipt"></i></span>
    <span class="float-icon i3"><i class="bi bi-truck"></i></span>
    <span class="float-icon i4"><i class="bi bi-credit-card"></i></span>
  </div>

  <div class="container page-wrap">
    <div class="hero-card d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <div class="hero-title">Order Details</div>
        <p class="hero-sub">Review customer details, payment data, ordered books, and tracking status from a premium admin layout.</p>
      </div>

      <div class="top-actions">
        <a href="/admin/orders" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-left"></i> Back to Orders
        </a>
      </div>
    </div>

    <div class="glass-card">
      <div class="section-title">Order Overview</div>
      <div class="section-sub">Core order information, payment mode, and customer account details.</div>

      <div class="top-grid">
        <div class="info-box">
          <div class="info-label">Order ID</div>
          <div class="info-value">#<%= order.id %></div>

          <div class="info-label">Order Date</div>
          <div class="info-value"><%= new Date(order.created_at).toLocaleString() %></div>

          <div class="info-label">Customer Name</div>
          <div class="info-value"><%= order.fullname || order.full_name || 'Customer' %></div>

          <div class="info-label">Customer Email</div>
          <div class="info-value"><%= order.email || order.email_address || 'No email' %></div>
        </div>

        <div class="info-box">
          <div class="info-label">Payment Method</div>
          <div class="info-value"><%= order.payment_method || 'COD' %></div>

          <% if (order.payment_id) { %>
            <div class="info-label">Payment ID</div>
            <div class="info-value"><%= order.payment_id %></div>
          <% } %>

          <% if (order.razorpay_order_id) { %>
            <div class="info-label">Razorpay Order ID</div>
            <div class="info-value"><%= order.razorpay_order_id %></div>
          <% } %>

          <div class="info-label">Current Status</div>
          <%
            let statusClass = "st-default";
            if (order.status === "PLACED") statusClass = "st-placed";
            else if (order.status === "PAID") statusClass = "st-paid";
            else if (order.status === "SHIPPED") statusClass = "st-shipped";
            else if (order.status === "OUT_FOR_DELIVERY") statusClass = "st-out";
            else if (order.status === "DELIVERED") statusClass = "st-delivered";
            else if (order.status === "CANCELLED") statusClass = "st-cancelled";
          %>
          <div class="status-pill <%= statusClass %>"><%= order.status %></div>
        </div>
      </div>
    </div>

    <div class="glass-card">
      <div class="section-title">Tracking Timeline</div>
      <div class="section-sub">Current delivery stage progression for this order.</div>

      <%
        const current = String(order.status || "");
        const placedDone = ["PLACED","PAID","SHIPPED","OUT_FOR_DELIVERY","DELIVERED"].includes(current);
        const paidDone = ["PAID","SHIPPED","OUT_FOR_DELIVERY","DELIVERED"].includes(current);
        const shippedDone = ["SHIPPED","OUT_FOR_DELIVERY","DELIVERED"].includes(current);
        const outDone = ["OUT_FOR_DELIVERY","DELIVERED"].includes(current);
        const deliveredDone = ["DELIVERED"].includes(current);
      %>

      <div class="track-wrap">
        <div class="track-step <%= placedDone ? 'done' : (current === 'PLACED' ? 'active' : '') %>">PLACED</div>
        <div class="track-step <%= paidDone ? 'done' : (current === 'PAID' ? 'active' : '') %>">PAID</div>
        <div class="track-step <%= shippedDone ? 'done' : (current === 'SHIPPED' ? 'active' : '') %>">SHIPPED</div>
        <div class="track-step <%= outDone ? 'done' : (current === 'OUT_FOR_DELIVERY' ? 'active' : '') %>">OUT FOR DELIVERY</div>
        <div class="track-step <%= deliveredDone ? 'done' : (current === 'DELIVERED' ? 'active' : '') %>">DELIVERED</div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-lg-8">
        <div class="glass-card">
          <div class="section-title">Ordered Books</div>
          <div class="section-sub">All books associated with this order.</div>

          <% items.forEach((item) => { %>
            <div class="order-book">
              <div class="book-img-wrap">
                <img
                  src="<%= item.image || '/uploads/default.png' %>"
                  alt="<%= item.name %>"
                  class="book-img"
                  onerror="this.onerror=null;this.src='/uploads/default.png'"
                >
              </div>

              <div>
                <div class="book-title"><%= item.name %></div>
                <div class="book-author"><i class="bi bi-person"></i> <%= item.author %></div>

                <div class="book-meta">
                  <span><i class="bi bi-box"></i> Qty: <%= item.qty %></span>
                  <span><i class="bi bi-tag"></i> Price Each: ₹<%= item.price_each %></span>
                </div>
              </div>

              <div class="book-price">₹<%= Number(item.price_each || 0) * Number(item.qty || 0) %></div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="summary-card">
          <div class="section-title">Order Summary</div>

          <div class="summary-row">
            <span>Items Total</span>
            <span>₹<%= itemsTotal %></span>
          </div>

          <div class="summary-row">
            <span>Shipping</span>
            <span>Free</span>
          </div>

          <div class="summary-row">
            <span>Payment</span>
            <span><%= order.payment_method || 'COD' %></span>
          </div>

          <div class="summary-total">
            <span>Grand Total</span>
            <span>₹<%= order.total %></span>
          </div>
        </div>

        <div class="address-box">
          <div class="section-title mb-2">Delivery Address</div>
          <strong><%= order.full_name || order.fullname || 'Customer' %></strong>
          <p>
            <%= order.email_address || order.email || '' %><br>
            <%= order.phone || 'Phone not available' %><br>
            <%= order.address_line || 'Address not available' %><br>
            <%= order.city || '' %> <%= order.pincode || '' %>
          </p>
        </div>
      </div>
    </div>
  </div>
</body>
</html>