<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Manage Categories • Admin</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <style>
    :root{
      --bg:#f4f8ff;
      --card:#ffffff;
      --text:#0f172a;
      --muted:#64748b;
      --border:#e6edf7;
      --primary:#2563eb;
      --shadow:0 18px 45px rgba(15,23,42,.08);
      --radius:26px;
    }

    body{
      background:
        radial-gradient(circle at top left, rgba(37,99,235,.08), transparent 22%),
        linear-gradient(180deg,#f8fbff,#eef4ff);
      color:var(--text);
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    .page-wrap{
      padding:30px 0 48px;
    }

    .hero-card,
    .cardx{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
    }

    .hero-card{
      padding:24px;
      margin-bottom:20px;
    }

    .hero-title{
      font-size:2rem;
      font-weight:900;
      margin-bottom:6px;
    }

    .hero-sub{
      color:var(--muted);
      margin-bottom:0;
    }

    .top-actions .btn{
      border-radius:12px;
      font-weight:800;
      padding:10px 14px;
    }

    .cardx{
      padding:22px;
      margin-bottom:20px;
    }

    .section-title{
      font-size:1.18rem;
      font-weight:900;
      margin-bottom:6px;
    }

    .section-sub{
      color:var(--muted);
      font-size:.94rem;
      margin-bottom:18px;
    }

    .soft-input{
      min-height:54px;
      border-radius:16px;
      border:1px solid #dbe3ef;
      padding-left:14px;
      padding-right:14px;
    }

    .soft-input:focus{
      border-color:#60a5fa;
      box-shadow:none;
    }

    .add-btn{
      min-height:54px;
      border:none;
      border-radius:16px;
      background:linear-gradient(135deg,#0f172a,#2563eb);
      color:#fff;
      font-weight:900;
      width:100%;
    }

    .cat-row{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:18px;
      padding:18px;
      border:1px solid #e9eef7;
      border-radius:20px;
      margin-bottom:14px;
      background:#fff;
      transition:.18s ease;
    }

    .cat-row:hover{
      transform:translateY(-2px);
      box-shadow:0 12px 26px rgba(15,23,42,.06);
    }

    .cat-left{
      display:flex;
      align-items:center;
      gap:14px;
      min-width:220px;
    }

    .cat-icon{
      width:50px;
      height:50px;
      display:grid;
      place-items:center;
      border-radius:16px;
      background:#eef4ff;
      color:#2563eb;
      font-size:1.2rem;
      flex-shrink:0;
    }

    .cat-name{
      font-weight:900;
      font-size:1.02rem;
      color:#111827;
    }

    .cat-meta{
      color:var(--muted);
      font-size:.9rem;
    }

    .count-pill{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border-radius:999px;
      padding:8px 12px;
      background:#f8fbff;
      border:1px solid #e6edf7;
      color:#334155;
      font-size:.82rem;
      font-weight:800;
      white-space:nowrap;
    }

    .row-form{
      display:flex;
      align-items:center;
      gap:10px;
      flex-wrap:wrap;
      width:100%;
      justify-content:flex-end;
    }

    .mini-input{
      min-width:220px;
      min-height:46px;
      border-radius:14px;
      border:1px solid #dbe3ef;
      padding:0 12px;
    }

    .mini-input:focus{
      border-color:#60a5fa;
      outline:none;
      box-shadow:none;
    }

    .mini-btn{
      border-radius:12px;
      font-weight:800;
      padding:10px 14px;
      white-space:nowrap;
    }

    @media (max-width: 991px){
      .cat-row{
        flex-direction:column;
        align-items:flex-start;
      }

      .row-form{
        justify-content:flex-start;
      }
    }
  </style>
</head>
<body>
  <div class="container page-wrap">
    <div class="hero-card d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <div class="hero-title">Manage Categories</div>
        <p class="hero-sub">Create, update, and organize categories for your bookstore catalog.</p>
      </div>

      <div class="top-actions d-flex gap-2 flex-wrap">
        <a href="/admin" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-left"></i> Dashboard
        </a>
      </div>
    </div>

    <div class="cardx">
      <div class="section-title">Add New Category</div>
      <div class="section-sub">Create a new shelf or genre section for books.</div>

      <form method="POST" action="/admin/categories/new" class="row g-3">
        <div class="col-md-9">
          <input type="text" name="name" class="form-control soft-input" placeholder="Enter category name" required>
        </div>
        <div class="col-md-3">
          <button class="add-btn">
            <i class="bi bi-plus-circle"></i> Add Category
          </button>
        </div>
      </form>
    </div>

    <div class="cardx">
      <div class="section-title">All Categories</div>
      <div class="section-sub">Update names or remove unused categories.</div>

      <% categories.forEach((c) => { %>
        <div class="cat-row">
          <div class="cat-left">
            <div class="cat-icon"><i class="bi bi-collection"></i></div>
            <div>
              <div class="cat-name"><%= c.name %></div>
              <div class="cat-meta">Category ID: #<%= c.id %></div>
            </div>
          </div>

          <div class="count-pill">
            <i class="bi bi-book"></i>&nbsp; <%= c.books_count %> book(s)
          </div>

          <div class="row-form">
            <form action="/admin/categories/<%= c.id %>/edit" method="POST" class="d-flex gap-2 flex-wrap">
              <input type="text" name="name" class="mini-input" value="<%= c.name %>" required>
              <button class="btn btn-outline-primary mini-btn">
                <i class="bi bi-pencil-square"></i> Update
              </button>
            </form>

            <form action="/admin/categories/<%= c.id %>/delete" method="POST">
              <button class="btn btn-outline-danger mini-btn" onclick="return confirm('Delete this category?')">
                <i class="bi bi-trash"></i> Delete
              </button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>