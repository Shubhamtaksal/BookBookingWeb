<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>My Profile • BookHub</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/navbar.css">
  <link rel="stylesheet" href="/css/common-footer.css">

  <style>
    :root{
      --bh-text:#0f172a;
      --bh-muted:#64748b;
      --bh-border:#e6eaf2;
      --bh-primary:#2563eb;
      --bh-danger:#ef4444;
      --bh-shadow:0 18px 45px rgba(15,23,42,.10);
      --bh-shadow2:0 10px 28px rgba(15,23,42,.08);
      --bh-radius:24px;
      --bh-radius2:30px;
    }

    *{box-sizing:border-box}
    html,body{overflow-x:hidden}

    body{
      background:
        radial-gradient(circle at top left, rgba(37,99,235,.10), transparent 22%),
        radial-gradient(circle at top right, rgba(14,165,233,.08), transparent 18%),
        linear-gradient(180deg,#f8fbff,#eef4ff);
      color:var(--bh-text);
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    .page-wrap{
      padding:26px 0 48px;
      position:relative;
      z-index:1;
    }

    .floating-shapes{
      position:fixed;
      inset:0;
      pointer-events:none;
      overflow:hidden;
      z-index:0;
    }

    .shape{
      position:absolute;
      border-radius:50%;
      filter:blur(10px);
      opacity:.22;
      animation:floatShape 12s ease-in-out infinite;
    }

    .shape.s1{
      width:180px;height:180px;
      background:rgba(37,99,235,.18);
      left:-40px;top:120px;
    }

    .shape.s2{
      width:220px;height:220px;
      background:rgba(14,165,233,.15);
      right:-60px;top:180px;
      animation-delay:2s;
    }

    .shape.s3{
      width:140px;height:140px;
      background:rgba(37,99,235,.12);
      left:20%;bottom:80px;
      animation-delay:4s;
    }

    @keyframes floatShape{
      0%,100%{transform:translateY(0) translateX(0)}
      50%{transform:translateY(-16px) translateX(8px)}
    }

    .hero-card,
    .profile-card{
      background:linear-gradient(135deg, rgba(255,255,255,.96), rgba(255,255,255,.90));
      border:1px solid rgba(255,255,255,.78);
      border-radius:var(--bh-radius2);
      box-shadow:var(--bh-shadow);
    }

    .hero-card{
      padding:24px;
      margin-bottom:22px;
      position:relative;
      overflow:hidden;
    }

    .hero-card::before{
      content:"";
      position:absolute;
      width:280px;
      height:280px;
      right:-90px;
      top:-90px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(37,99,235,.14), transparent 65%);
    }

    .hero-title{
      font-size:2rem;
      font-weight:900;
      line-height:1.1;
      margin-bottom:6px;
    }

    .hero-sub{
      color:var(--bh-muted);
      margin-bottom:0;
    }

    .profile-card{
      padding:24px;
    }

    .avatar-card{
      background:#fff;
      border:1px solid var(--bh-border);
      border-radius:24px;
      box-shadow:var(--bh-shadow2);
      padding:22px;
      height:100%;
      text-align:center;
    }

    .avatar-wrap{
      width:150px;
      height:150px;
      margin:0 auto 16px;
      border-radius:50%;
      padding:6px;
      background:linear-gradient(135deg,#2563eb,#0ea5e9);
      box-shadow:0 18px 32px rgba(37,99,235,.18);
    }

    .avatar-img{
      width:100%;
      height:100%;
      object-fit:cover;
      border-radius:50%;
      background:#fff;
      border:4px solid #fff;
      display:block;
    }

    .avatar-name{
      font-size:1.2rem;
      font-weight:900;
      margin-bottom:4px;
      color:#111827;
    }

    .avatar-email{
      color:var(--bh-muted);
      font-size:.94rem;
      margin-bottom:12px;
      word-break:break-word;
    }

    .avatar-chip{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      background:#eef4ff;
      color:#2563eb;
      font-size:.82rem;
      font-weight:900;
    }

    .form-card{
      background:#fff;
      border:1px solid var(--bh-border);
      border-radius:24px;
      box-shadow:var(--bh-shadow2);
      padding:22px;
      height:100%;
    }

    .section-title{
      font-size:1.18rem;
      font-weight:900;
      margin-bottom:6px;
    }

    .section-sub{
      color:var(--bh-muted);
      margin-bottom:18px;
      font-size:.93rem;
    }

    .soft-label{
      font-weight:800;
      color:#111827;
      margin-bottom:8px;
      font-size:.95rem;
    }

    .soft-input,
    .soft-select{
      min-height:54px;
      border-radius:16px;
      border:1px solid #dbe3ef;
      box-shadow:none !important;
      padding-left:14px;
      padding-right:14px;
      font-weight:600;
    }

    .soft-input:focus,
    .soft-select:focus{
      border-color:#60a5fa;
    }

    .upload-note{
      color:var(--bh-muted);
      font-size:.85rem;
      margin-top:8px;
      line-height:1.6;
    }

    .save-btn{
      min-height:52px;
      border:none;
      border-radius:16px;
      background:linear-gradient(135deg,#0f172a,#2563eb);
      color:#fff;
      font-weight:900;
      padding:0 18px;
      box-shadow:0 18px 34px rgba(37,99,235,.18);
    }

    .save-btn:hover{
      color:#fff;
      transform:translateY(-1px);
    }

    @media (max-width: 767px){
      .hero-title{
        font-size:1.7rem;
      }

      .avatar-wrap{
        width:130px;
        height:130px;
      }
    }
  </style>
</head>
<body>

  <div class="floating-shapes">
    <span class="shape s1"></span>
    <span class="shape s2"></span>
    <span class="shape s3"></span>
  </div>

  <%- include('partials/navbar') %>

  <div class="container page-wrap">
    <div class="hero-card">
      <div class="hero-title">My Profile</div>
      <p class="hero-sub">Manage your personal details and profile picture for a better BookHub experience.</p>
    </div>

    <%
      let img = userData?.profile_image;
      if (!img) {
        if ((userData?.gender || '').toLowerCase() === 'female') {
          img = '/images/female.png';
        } else {
          img = '/images/male.png';
        }
      }
    %>

    <div class="profile-card">
      <div class="row g-4">
        <div class="col-lg-4">
          <div class="avatar-card">
            <div class="avatar-wrap">
              <img
                src="<%= img %>"
                alt="Profile Photo"
                class="avatar-img"
                id="profilePreview"
                onerror="this.onerror=null;this.src='/images/male.png'"
              >
            </div>

            <div class="avatar-name"><%= userData?.fullname || 'User' %></div>
            <div class="avatar-email"><%= userData?.email || '' %></div>

            <div class="avatar-chip">
              <i class="bi bi-person-badge"></i>
              <span><%= userData?.role || 'USER' %></span>
            </div>
          </div>
        </div>

        <div class="col-lg-8">
          <div class="form-card">
            <div class="section-title">Update Profile</div>
            <div class="section-sub">Edit your details below and save changes.</div>

            <form method="POST" action="/profile/update" enctype="multipart/form-data">
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="soft-label">Full Name</label>
                  <input
                    type="text"
                    name="fullname"
                    class="form-control soft-input"
                    value="<%= userData?.fullname || '' %>"
                    required
                  >
                </div>

                <div class="col-md-6">
                  <label class="soft-label">Phone Number</label>
                  <input
                    type="text"
                    name="phone"
                    class="form-control soft-input"
                    value="<%= userData?.phone || '' %>"
                    placeholder="Enter phone number"
                  >
                </div>

                <div class="col-md-6">
                  <label class="soft-label">City</label>
                  <input
                    type="text"
                    name="city"
                    class="form-control soft-input"
                    value="<%= userData?.city || '' %>"
                    placeholder="Enter city"
                  >
                </div>

                <div class="col-md-6">
                  <label class="soft-label">Gender</label>
                  <select name="gender" class="form-select soft-select">
                    <option value="male" <%= (userData?.gender || '').toLowerCase() === 'male' ? 'selected' : '' %>>Male</option>
                    <option value="female" <%= (userData?.gender || '').toLowerCase() === 'female' ? 'selected' : '' %>>Female</option>
                  </select>
                </div>

                <div class="col-12">
                  <label class="soft-label">Profile Photo</label>
                  <input
                    type="file"
                    name="profile"
                    class="form-control soft-input"
                    accept="image/*"
                    id="profileInput"
                  >
                  <div class="upload-note">
                    Upload a profile image. If no image is uploaded, a default avatar is shown based on gender.
                  </div>
                </div>

                <div class="col-12 mt-2">
                  <button class="save-btn" type="submit">
                    <i class="bi bi-save"></i> Save Changes
                  </button>
                </div>
              </div>
            </form>

          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script>
    const profileInput = document.getElementById("profileInput");
    const profilePreview = document.getElementById("profilePreview");

    profileInput?.addEventListener("change", function () {
      const file = this.files && this.files[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = function (e) {
        profilePreview.src = e.target.result;
      };
      reader.readAsDataURL(file);
    });
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>