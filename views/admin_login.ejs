<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin Login • BookHub</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <style>
    :root{
      --bg1:#0f172a;
      --bg2:#1d4ed8;
      --bg3:#60a5fa;
      --card:#ffffff;
      --text:#0f172a;
      --muted:#64748b;
      --border:#dbe7fb;
      --primary:#2563eb;
      --shadow:0 28px 70px rgba(0,0,0,.22);
    }

    *{ box-sizing:border-box; }

    body{
      min-height:100vh;
      margin:0;
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
      background:
        radial-gradient(circle at 10% 10%, rgba(255,255,255,.12), transparent 18%),
        radial-gradient(circle at 85% 15%, rgba(96,165,250,.18), transparent 18%),
        radial-gradient(circle at 80% 80%, rgba(255,255,255,.08), transparent 22%),
        linear-gradient(135deg,var(--bg1) 0%, var(--bg2) 55%, var(--bg3) 100%);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
      overflow:hidden;
      position:relative;
    }

    .bg-book{
      position:absolute;
      inset:auto;
      opacity:.08;
      font-size:160px;
      color:#fff;
      animation:floaty 8s ease-in-out infinite;
      user-select:none;
      pointer-events:none;
    }

    .bg-book.book1{ top:40px; left:40px; transform:rotate(-12deg); }
    .bg-book.book2{ right:40px; top:90px; transform:rotate(10deg); animation-delay:1.5s; }
    .bg-book.book3{ bottom:30px; left:10%; transform:rotate(-8deg); animation-delay:3s; }
    .bg-book.book4{ bottom:20px; right:10%; transform:rotate(12deg); animation-delay:4.5s; }

    @keyframes floaty{
      0%,100%{ transform:translateY(0) rotate(0deg); }
      50%{ transform:translateY(-10px) rotate(2deg); }
    }

    .login-shell{
      width:100%;
      max-width:1120px;
      display:grid;
      grid-template-columns:1.15fr .95fr;
      gap:24px;
      align-items:stretch;
    }

    .showcase-card,
    .login-card{
      border-radius:34px;
      overflow:hidden;
      box-shadow:var(--shadow);
      position:relative;
    }

    .showcase-card{
      background:
        linear-gradient(135deg, rgba(255,255,255,.12), rgba(255,255,255,.04));
      border:1px solid rgba(255,255,255,.16);
      backdrop-filter:blur(14px);
      color:#fff;
      padding:40px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
    }

    .showcase-badge{
      display:inline-flex;
      align-items:center;
      gap:10px;
      width:max-content;
      padding:10px 16px;
      border-radius:999px;
      background:rgba(255,255,255,.14);
      border:1px solid rgba(255,255,255,.18);
      font-weight:800;
      letter-spacing:.2px;
      margin-bottom:22px;
    }

    .showcase-title{
      font-size:3rem;
      line-height:1.08;
      font-weight:900;
      max-width:560px;
      margin-bottom:16px;
    }

    .showcase-sub{
      color:rgba(255,255,255,.84);
      font-size:1.04rem;
      max-width:560px;
      line-height:1.7;
      margin-bottom:24px;
    }

    .feature-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:14px;
      max-width:620px;
    }

    .feature-item{
      display:flex;
      align-items:center;
      gap:12px;
      padding:14px 16px;
      border-radius:20px;
      background:rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.12);
      font-weight:700;
      color:#fff;
    }

    .feature-icon{
      width:42px;
      height:42px;
      border-radius:14px;
      display:grid;
      place-items:center;
      background:rgba(255,255,255,.16);
      font-size:1.05rem;
      flex-shrink:0;
    }

    .stats-row{
      display:flex;
      gap:14px;
      flex-wrap:wrap;
      margin-top:28px;
    }

    .stat-chip{
      padding:12px 16px;
      border-radius:18px;
      background:rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.12);
      min-width:140px;
    }

    .stat-val{
      font-size:1.35rem;
      font-weight:900;
      line-height:1;
      margin-bottom:6px;
    }

    .stat-lbl{
      color:rgba(255,255,255,.75);
      font-size:.88rem;
      font-weight:700;
    }

    .login-card{
      background:rgba(255,255,255,.95);
      border:1px solid rgba(255,255,255,.85);
      backdrop-filter:blur(16px);
      padding:34px;
    }

    .login-glow{
      position:absolute;
      width:220px;
      height:220px;
      right:-70px;
      top:-70px;
      background:radial-gradient(circle, rgba(37,99,235,.18), transparent 70%);
      pointer-events:none;
    }

    .brand-row{
      display:flex;
      align-items:center;
      gap:12px;
      margin-bottom:22px;
    }

    .brand-icon{
      width:54px;
      height:54px;
      border-radius:18px;
      display:grid;
      place-items:center;
      background:linear-gradient(135deg,#0f172a,#2563eb);
      color:#fff;
      font-size:1.3rem;
      box-shadow:0 14px 30px rgba(37,99,235,.18);
    }

    .brand-title{
      font-size:1.45rem;
      font-weight:900;
      color:var(--text);
      margin-bottom:2px;
    }

    .brand-sub{
      color:var(--muted);
      font-size:.92rem;
    }

    .login-heading{
      font-size:2rem;
      font-weight:900;
      color:var(--text);
      margin-bottom:8px;
      line-height:1.15;
    }

    .login-copy{
      color:var(--muted);
      margin-bottom:22px;
      font-size:.96rem;
      line-height:1.65;
    }

    .input-group-custom{
      position:relative;
      margin-bottom:16px;
    }

    .input-icon{
      position:absolute;
      left:16px;
      top:50%;
      transform:translateY(-50%);
      color:#64748b;
      font-size:1rem;
      z-index:2;
    }

    .soft-input{
      min-height:56px;
      border-radius:18px;
      border:1px solid var(--border);
      background:#fff;
      padding-left:46px;
      padding-right:14px;
      font-weight:600;
    }

    .soft-input:focus{
      border-color:#60a5fa;
      box-shadow:0 0 0 .2rem rgba(37,99,235,.08);
    }

    .input-label{
      font-weight:800;
      color:#111827;
      margin-bottom:8px;
      font-size:.95rem;
    }

    .admin-btn{
      width:100%;
      min-height:58px;
      border:none;
      border-radius:18px;
      background:linear-gradient(135deg,#0f172a,#2563eb);
      color:#fff;
      font-weight:900;
      font-size:1rem;
      box-shadow:0 18px 34px rgba(37,99,235,.18);
      transition:transform .18s ease, box-shadow .18s ease;
    }

    .admin-btn:hover{
      transform:translateY(-1px);
      box-shadow:0 22px 38px rgba(37,99,235,.24);
    }

    .helper-row{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-top:16px;
      flex-wrap:wrap;
    }

    .helper-chip{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      background:#f8fbff;
      border:1px solid #e7eefb;
      color:#334155;
      font-size:.82rem;
      font-weight:800;
    }

    .alert{
      border-radius:18px;
      font-weight:700;
      margin-bottom:18px;
    }

    @media (max-width: 991px){
      .login-shell{
        grid-template-columns:1fr;
        max-width:620px;
      }

      .showcase-card{
        display:none;
      }
    }

    @media (max-width: 576px){
      .login-card{
        padding:24px;
        border-radius:28px;
      }

      .login-heading{
        font-size:1.7rem;
      }
    }
  </style>
</head>
<body>
  <div class="bg-book book1"><i class="bi bi-book-half"></i></div>
  <div class="bg-book book2"><i class="bi bi-journal-bookmark-fill"></i></div>
  <div class="bg-book book3"><i class="bi bi-book"></i></div>
  <div class="bg-book book4"><i class="bi bi-bookmarks-fill"></i></div>

  <div class="login-shell">
    <div class="showcase-card">
      <div>
        <div class="showcase-badge">
          <i class="bi bi-shield-lock-fill"></i>
          BookHub Admin Console
        </div>

        <div class="showcase-title">
          Manage your bookstore with a premium control panel.
        </div>

        <div class="showcase-sub">
          Access books, inventory, categories, and customer orders in one secure dashboard designed for a smooth and professional admin experience.
        </div>

        <div class="feature-grid">
          <div class="feature-item">
            <div class="feature-icon"><i class="bi bi-book-half"></i></div>
            <div>Book inventory control</div>
          </div>

          <div class="feature-item">
            <div class="feature-icon"><i class="bi bi-grid-3x3-gap"></i></div>
            <div>Category management</div>
          </div>

          <div class="feature-item">
            <div class="feature-icon"><i class="bi bi-receipt-cutoff"></i></div>
            <div>Order handling</div>
          </div>

          <div class="feature-item">
            <div class="feature-icon"><i class="bi bi-truck"></i></div>
            <div>Status tracking</div>
          </div>
        </div>
      </div>

      <div class="stats-row">
        <div class="stat-chip">
          <div class="stat-val">Fast</div>
          <div class="stat-lbl">Admin workflow</div>
        </div>

        <div class="stat-chip">
          <div class="stat-val">Secure</div>
          <div class="stat-lbl">Role-based access</div>
        </div>

        <div class="stat-chip">
          <div class="stat-val">Clean</div>
          <div class="stat-lbl">Book-store themed UI</div>
        </div>
      </div>
    </div>

    <div class="login-card">
      <div class="login-glow"></div>

      <div class="brand-row">
        <div class="brand-icon">
          <i class="bi bi-shield-check"></i>
        </div>
        <div>
          <div class="brand-title">BookHub Admin</div>
          <div class="brand-sub">Secure access to the management panel</div>
        </div>
      </div>

      <div class="login-heading">Welcome back, Admin</div>
      <div class="login-copy">
        Sign in to manage books, orders, categories, and your bookstore operations with full control.
      </div>

      <% if (error) { %>
        <div class="alert alert-danger">
          <i class="bi bi-exclamation-triangle"></i> <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/admin-login">
        <label class="input-label">Admin Email</label>
        <div class="input-group-custom">
          <i class="bi bi-envelope input-icon"></i>
          <input type="email" name="email" class="form-control soft-input" placeholder="Enter admin email" required>
        </div>

        <label class="input-label">Password</label>
        <div class="input-group-custom">
          <i class="bi bi-lock input-icon"></i>
          <input type="password" name="password" class="form-control soft-input" placeholder="Enter password" required>
        </div>

        <button class="admin-btn mt-2">
          <i class="bi bi-box-arrow-in-right"></i> Login to Admin Panel
        </button>
      </form>

      <div class="helper-row">
        <div class="helper-chip">
          <i class="bi bi-shield-lock"></i> Secure login
        </div>

        <div class="helper-chip">
          <i class="bi bi-stars"></i> Premium control panel
        </div>
      </div>
    </div>
  </div>
</body>
</html>