<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin Dashboard • BookHub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body{
      background:#f8fafc;
      color:#0f172a;
    }
    .page-wrap{
      padding:32px 0 50px;
    }
    .hero-card{
      background:linear-gradient(135deg,#0f172a,#2563eb);
      color:#fff;
      border-radius:28px;
      padding:28px;
      box-shadow:0 20px 50px rgba(15,23,42,.16);
      margin-bottom:24px;
    }
    .hero-title{
      font-size:2rem;
      font-weight:900;
      margin-bottom:6px;
    }
    .hero-sub{
      opacity:.88;
      margin-bottom:0;
    }
    .stat-card, .quick-card{
      background:#fff;
      border-radius:24px;
      padding:24px;
      box-shadow:0 12px 30px rgba(15,23,42,.06);
      height:100%;
    }
    .stat-icon{
      width:54px;
      height:54px;
      border-radius:16px;
      display:grid;
      place-items:center;
      font-size:1.35rem;
      margin-bottom:16px;
      background:#eff6ff;
      color:#2563eb;
    }
    .stat-title{
      color:#64748b;
      font-weight:700;
      margin-bottom:8px;
    }
    .stat-value{
      font-size:2rem;
      font-weight:900;
      line-height:1;
    }
    .section-title{
      font-size:1.25rem;
      font-weight:900;
      margin-bottom:16px;
    }
    .quick-link{
      display:flex;
      align-items:center;
      justify-content:space-between;
      text-decoration:none;
      color:#111827;
      border:1px solid #e5e7eb;
      border-radius:18px;
      padding:16px 18px;
      margin-bottom:12px;
      transition:.18s ease;
    }
    .quick-link:hover{
      transform:translateY(-2px);
      box-shadow:0 10px 24px rgba(15,23,42,.06);
      color:#2563eb;
    }
  </style>
</head>
<body>
  <div class="container page-wrap">
    <div class="hero-card d-flex justify-content-between align-items-start flex-wrap gap-3">
      <div>
        <div class="hero-title">Admin Dashboard</div>
        <p class="hero-sub">Manage books, categories, and customer orders from one place.</p>
      </div>

      <div class="d-flex gap-2 flex-wrap">
        <a href="/admin/books" class="btn btn-light"><i class="bi bi-book"></i> Manage Books</a>
        <a href="/admin/orders" class="btn btn-outline-light"><i class="bi bi-bag-check"></i> Orders</a>
        <a href="/admin/categories" class="btn btn-outline-light"><i class="bi bi-grid"></i> Categories</a>
      </div>
    </div>

    <div class="row g-4 mb-4">
      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-icon"><i class="bi bi-people"></i></div>
          <div class="stat-title">Total Users</div>
          <div class="stat-value"><%= usersCount %></div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-icon"><i class="bi bi-book-half"></i></div>
          <div class="stat-title">Total Books</div>
          <div class="stat-value"><%= booksCount %></div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-icon"><i class="bi bi-receipt"></i></div>
          <div class="stat-title">Total Orders</div>
          <div class="stat-value"><%= ordersCount %></div>
        </div>
      </div>
    </div>

    <div class="quick-card">
      <div class="section-title">Quick Actions</div>

      <a href="/admin/books/new" class="quick-link">
        <span><i class="bi bi-plus-circle"></i> Add New Book</span>
        <i class="bi bi-arrow-right"></i>
      </a>

      <a href="/admin/books" class="quick-link">
        <span><i class="bi bi-pencil-square"></i> Edit / Delete Books</span>
        <i class="bi bi-arrow-right"></i>
      </a>

      <a href="/admin/orders" class="quick-link">
        <span><i class="bi bi-truck"></i> Update Order Status</span>
        <i class="bi bi-arrow-right"></i>
      </a>

      <a href="/admin/categories" class="quick-link">
        <span><i class="bi bi-collection"></i> Manage Categories</span>
        <i class="bi bi-arrow-right"></i>
      </a>
    </div>
  </div>
</body>
</html>