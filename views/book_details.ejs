<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= book.name %> • BookHub</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <style>
    :root{
      --bh-bg:#f6f8fc;
      --bh-card:#ffffff;
      --bh-text:#0f172a;
      --bh-muted:#64748b;
      --bh-border:#e6eaf2;
      --bh-primary:#2563eb;
      --bh-primary2:#0ea5e9;
      --bh-shadow:0 18px 45px rgba(15,23,42,.10);
      --bh-shadow2:0 10px 28px rgba(15,23,42,.08);
      --bh-radius:24px;
      --bh-radius2:30px;
    }

    *{box-sizing:border-box}
    html,body{overflow-x:hidden}

    body{
      background:
        radial-gradient(circle at top left, rgba(37,99,235,.10), transparent 22%),
        radial-gradient(circle at top right, rgba(14,165,233,.08), transparent 18%),
        linear-gradient(180deg,#f8fbff,#eef4ff);
      color:var(--bh-text);
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    .page-wrap{
      padding:26px 0 48px;
    }

    .floating-books{
      position:fixed;
      inset:0;
      pointer-events:none;
      overflow:hidden;
      z-index:0;
    }

    .float-book{
      position:absolute;
      color:rgba(37,99,235,.10);
      filter:blur(.2px);
      animation:floatBook 14s ease-in-out infinite;
      user-select:none;
    }

    .float-book i{font-size:58px}
    .float-book.b1{top:10%;left:6%;animation-duration:12s}
    .float-book.b2{top:18%;right:10%;animation-duration:15s;animation-delay:1s}
    .float-book.b3{bottom:18%;left:12%;animation-duration:13s;animation-delay:2s}
    .float-book.b4{bottom:10%;right:8%;animation-duration:16s;animation-delay:3s}

    @keyframes floatBook{
      0%,100%{transform:translateY(0) rotate(0deg) scale(1);opacity:.45}
      25%{transform:translateY(-18px) rotate(4deg) scale(1.04);opacity:.7}
      50%{transform:translateY(10px) rotate(-3deg) scale(.98);opacity:.5}
      75%{transform:translateY(-12px) rotate(2deg) scale(1.02);opacity:.68}
    }

    .page-wrap,
    footer{
      position:relative;
      z-index:1;
    }

    .top-bar{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-bottom:16px;
      flex-wrap:wrap;
    }

    .back-btn{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:10px 14px;
      border-radius:14px;
      border:1px solid var(--bh-border);
      background:#fff;
      color:var(--bh-text);
      text-decoration:none;
      font-weight:800;
      box-shadow:var(--bh-shadow2);
    }

    .back-btn:hover{
      color:var(--bh-primary);
    }

    .crumb{
      color:var(--bh-muted);
      font-size:.9rem;
      font-weight:700;
    }

    .main-card,
    .info-card,
    .related-wrap{
      background:linear-gradient(135deg, rgba(255,255,255,.96), rgba(255,255,255,.90));
      border:1px solid rgba(255,255,255,.78);
      border-radius:var(--bh-radius2);
      box-shadow:var(--bh-shadow);
    }

    .main-card{
      padding:26px;
      overflow:hidden;
      position:relative;
      margin-bottom:22px;
    }

    .main-card::before{
      content:"";
      position:absolute;
      width:320px;
      height:320px;
      right:-120px;
      top:-120px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(37,99,235,.14), transparent 70%);
    }

    .image-panel{
      background:linear-gradient(180deg,#f8fbff,#ffffff);
      border:1px solid var(--bh-border);
      border-radius:28px;
      min-height:520px;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:26px;
      position:relative;
      overflow:hidden;
      box-shadow:var(--bh-shadow2);
      perspective:1000px;
    }

    .image-panel::after{
      content:"";
      position:absolute;
      left:50%;
      bottom:-30px;
      transform:translateX(-50%);
      width:70%;
      height:70px;
      background:radial-gradient(circle, rgba(59,130,246,.28), transparent 72%);
      pointer-events:none;
    }

    .main-book-image{
      width:min(320px, 100%);
      height:430px;
      object-fit:cover;
      border-radius:20px;
      background:#fff;
      border:1px solid rgba(0,0,0,.06);
      box-shadow:0 26px 52px rgba(15,23,42,.18);
      transition:.45s ease;
      transform-style:preserve-3d;
    }

    .image-panel:hover .main-book-image{
      transform:rotateY(-10deg) rotateX(3deg) scale(1.05);
      box-shadow:0 32px 60px rgba(15,23,42,.22);
    }

    .discount-badge{
      position:absolute;
      top:16px;
      left:16px;
      z-index:3;
      background:#ef4444;
      color:#fff;
      padding:8px 12px;
      border-radius:999px;
      font-size:.85rem;
      font-weight:900;
      box-shadow:0 10px 18px rgba(0,0,0,.14);
      animation:pulseBadge 2s infinite;
    }

    @keyframes pulseBadge{
      0%,100%{transform:scale(1)}
      50%{transform:scale(1.08)}
    }

    .book-meta{
      padding-left:8px;
    }

    .book-category{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      background:#eef4ff;
      color:var(--bh-primary);
      font-size:.84rem;
      font-weight:800;
      margin-bottom:14px;
    }

    .book-title{
      font-size:clamp(2rem, 3vw, 3.1rem);
      line-height:1.08;
      font-weight:900;
      margin-bottom:12px;
    }

    .book-author{
      color:var(--bh-muted);
      font-size:1rem;
      margin-bottom:14px;
      font-weight:700;
    }

    .stars{
      color:#f59e0b;
      font-size:.96rem;
      margin-bottom:16px;
    }

    .desc{
      color:#475569;
      line-height:1.8;
      margin-bottom:18px;
    }

    .price-box{
      display:flex;
      align-items:center;
      gap:12px;
      flex-wrap:wrap;
      margin-bottom:16px;
    }

    .price-box strong{
      font-size:2rem;
      color:var(--bh-primary);
      font-weight:900;
    }

    .old-price{
      color:#94a3b8;
      text-decoration:line-through;
      font-size:1.06rem;
      font-weight:800;
    }

    .save-chip{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:7px 12px;
      border-radius:999px;
      background:#dcfce7;
      color:#166534;
      font-size:.82rem;
      font-weight:900;
    }

    .meta-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:12px;
      margin-bottom:18px;
    }

    .meta-item{
      background:#fff;
      border:1px solid var(--bh-border);
      border-radius:18px;
      padding:14px;
      box-shadow:var(--bh-shadow2);
    }

    .meta-label{
      color:var(--bh-muted);
      font-size:.82rem;
      font-weight:700;
      margin-bottom:4px;
    }

    .meta-value{
      color:#111827;
      font-weight:900;
    }

    .stock-ok{
      color:#16a34a;
    }

    .stock-low{
      color:#d97706;
    }

    .action-row{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
      margin-bottom:16px;
    }

    .action-btn,
    .action-btn-outline{
      min-height:54px;
      border-radius:16px;
      font-weight:900;
      padding:0 22px;
      text-decoration:none;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      transition:.25s ease;
    }

    .action-btn{
      background:linear-gradient(135deg,#0f172a,#2563eb);
      color:#fff;
      box-shadow:0 16px 28px rgba(37,99,235,.20);
    }

    .action-btn:hover{
      color:#fff;
      transform:translateY(-2px);
    }

    .action-btn-outline{
      background:#fff;
      color:var(--bh-text);
      border:1px solid #dbe3ef;
    }

    .action-btn-outline:hover{
      color:var(--bh-primary);
      transform:translateY(-2px);
    }

    .mini-note{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
    }

    .mini-note .chip{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:10px 12px;
      border-radius:999px;
      background:#fff;
      border:1px solid var(--bh-border);
      color:#334155;
      font-size:.84rem;
      font-weight:800;
      box-shadow:var(--bh-shadow2);
    }

    .info-card{
      padding:22px;
      margin-bottom:22px;
    }

    .section-title{
      font-size:1.3rem;
      font-weight:900;
      margin-bottom:6px;
    }

    .section-sub{
      color:var(--bh-muted);
      margin-bottom:18px;
    }

    .detail-grid{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:14px;
    }

    .detail-box{
      background:#fff;
      border:1px solid var(--bh-border);
      border-radius:20px;
      padding:18px;
      box-shadow:var(--bh-shadow2);
      transition:.28s ease;
    }

    .detail-box:hover{
      transform:translateY(-4px);
    }

    .detail-icon{
      width:52px;
      height:52px;
      display:grid;
      place-items:center;
      border-radius:16px;
      background:#eef4ff;
      color:var(--bh-primary);
      font-size:1.2rem;
      margin-bottom:12px;
    }

    .detail-box h4{
      font-size:1rem;
      font-weight:900;
      margin-bottom:6px;
    }

    .detail-box p{
      color:var(--bh-muted);
      margin-bottom:0;
      font-size:.92rem;
      line-height:1.6;
    }

    .related-wrap{
      padding:24px;
    }

    .related-head{
      display:flex;
      justify-content:space-between;
      align-items:end;
      gap:12px;
      flex-wrap:wrap;
      margin-bottom:18px;
    }

    .related-link{
      color:var(--bh-primary);
      font-weight:800;
      text-decoration:none;
    }

    .book-card{
      position:relative;
      background:#fff;
      border:1px solid var(--bh-border);
      border-radius:24px;
      overflow:hidden;
      box-shadow:var(--bh-shadow2);
      transition:.35s ease;
      height:100%;
    }

    .book-card:hover{
      transform:translateY(-8px) scale(1.02);
      box-shadow:0 26px 52px rgba(15,23,42,.14);
    }

    .book-card::before{
      content:"";
      position:absolute;
      top:0;
      left:-120%;
      width:70%;
      height:100%;
      background:linear-gradient(120deg,transparent,rgba(255,255,255,.4),transparent);
      transform:skewX(-18deg);
      opacity:0;
      z-index:1;
    }

    .book-card:hover::before{
      opacity:1;
      animation:shine 1s ease;
    }

    .book-cover{
      perspective:1000px;
      display:flex;
      justify-content:center;
      align-items:center;
      padding:18px 18px 8px;
      min-height:250px;
      position:relative;
      z-index:2;
    }

    .book-cover img{
      width:160px;
      height:210px;
      object-fit:cover;
      border-radius:16px;
      background:#fff;
      border:1px solid rgba(0,0,0,.05);
      box-shadow:0 18px 36px rgba(15,23,42,.14);
      transform-style:preserve-3d;
      transition:.45s ease;
    }

    .book-card:hover .book-cover img{
      transform:rotateY(-10deg) rotateX(3deg) scale(1.06);
    }

    .quick-preview{
      position:absolute;
      left:14px;
      right:14px;
      bottom:14px;
      background:rgba(15,23,42,.94);
      color:#fff;
      border-radius:18px;
      padding:14px;
      opacity:0;
      visibility:hidden;
      transform:translateY(16px) scale(.97);
      transition:all .28s ease;
      z-index:4;
    }

    .book-card:hover .quick-preview{
      opacity:1;
      visibility:visible;
      transform:translateY(0) scale(1);
    }

    .qp-title{
      font-size:.98rem;
      font-weight:900;
      margin-bottom:4px;
    }

    .qp-author,
    .qp-stock{
      font-size:.85rem;
      color:rgba(255,255,255,.78);
      margin-bottom:4px;
    }

    .qp-price{
      font-size:1.1rem;
      font-weight:900;
      color:#7dd3fc;
      margin-top:4px;
    }

    .book-body{
      padding:14px 18px 18px;
      position:relative;
      z-index:2;
    }

    .mini-cat{
      color:var(--bh-primary);
      font-size:.78rem;
      font-weight:800;
      margin-bottom:6px;
    }

    .mini-title{
      font-size:1rem;
      font-weight:900;
      line-height:1.35;
      min-height:48px;
      margin-bottom:6px;
    }

    .mini-author{
      color:var(--bh-muted);
      font-size:.9rem;
      margin-bottom:8px;
    }

    .mini-price{
      color:var(--bh-primary);
      font-size:1.1rem;
      font-weight:900;
      margin-bottom:12px;
    }

    .mini-actions{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }

    .mini-btn{
      min-height:42px;
      border-radius:14px;
      font-weight:900;
    }

    @media (max-width: 991px){
      .detail-grid{
        grid-template-columns:1fr;
      }

      .image-panel{
        min-height:420px;
      }

      .main-book-image{
        height:360px;
      }

      .book-meta{
        padding-left:0;
        padding-top:6px;
      }
    }

    @media (max-width: 767px){
      .main-card,
      .related-wrap,
      .info-card{
        padding:18px;
      }

      .image-panel{
        min-height:340px;
        padding:18px;
      }

      .main-book-image{
        width:220px;
        height:300px;
      }

      .book-title{
        font-size:1.8rem;
      }

      .meta-grid{
        grid-template-columns:1fr;
      }

      .action-row{
        flex-direction:column;
      }

      .action-btn,
      .action-btn-outline{
        width:100%;
      }

      .mini-actions{
        grid-template-columns:1fr;
      }
    }
  </style>
</head>
<body>

  <div class="floating-books">
    <span class="float-book b1"><i class="bi bi-book"></i></span>
    <span class="float-book b2"><i class="bi bi-book-half"></i></span>
    <span class="float-book b3"><i class="bi bi-journal-bookmark"></i></span>
    <span class="float-book b4"><i class="bi bi-book"></i></span>
  </div>

  <%- include('partials/navbar') %>

  <div class="container page-wrap">
    <div class="top-bar">
      <div class="crumb">
        <i class="bi bi-house"></i> Home / Books / <%= book.name %>
      </div>

      <a href="/books" class="back-btn">
        <i class="bi bi-arrow-left"></i> Back to Books
      </a>
    </div>

    <div class="main-card">
      <div class="row g-4 align-items-start">
        <div class="col-lg-5">
          <div class="image-panel">
            <% if (Number(book.discount || 0) > 0) { %>
              <div class="discount-badge"><%= book.discount %>% OFF</div>
            <% } %>

            <img
              src="<%= book.image || '/uploads/default.png' %>"
              alt="<%= book.name %>"
              class="main-book-image"
              onerror="this.onerror=null;this.src='/uploads/default.png'"
            >
          </div>
        </div>

        <div class="col-lg-7">
          <div class="book-meta">
            <div class="book-category">
              <i class="bi bi-bookmark-star"></i>
              <%= book.category_name || 'Book Category' %>
            </div>

            <h1 class="book-title"><%= book.name %></h1>

            <div class="book-author">
              <i class="bi bi-person"></i> by <%= book.author %>
            </div>

            <div class="stars">
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-half"></i>
              <span class="ms-2 text-muted" style="font-size:.9rem;">4.5 / 5 Reader Rating</span>
            </div>

            <p class="desc">
              Explore this title in a rich, premium bookstore experience. Perfect for readers who want a clean interface, strong details, and easy purchasing with modern design and smooth animations.
            </p>

            <%
              const finalPrice = Math.max(0, Number(book.price || 0) - Math.round((Number(book.price || 0) * Number(book.discount || 0)) / 100));
            %>

            <div class="price-box">
              <strong>₹<%= finalPrice %></strong>
              <% if (Number(book.discount || 0) > 0) { %>
                <span class="old-price">₹<%= book.price %></span>
                <span class="save-chip">
                  <i class="bi bi-patch-check-fill"></i> Save <%= book.discount %>%
                </span>
              <% } %>
            </div>

            <div class="meta-grid">
              <div class="meta-item">
                <div class="meta-label">Availability</div>
                <div class="meta-value <%= Number(book.available || 0) > 5 ? 'stock-ok' : 'stock-low' %>">
                  <%= Number(book.available || 0) > 0 ? `In Stock: ${book.available}` : 'Out of Stock' %>
                </div>
              </div>

              <div class="meta-item">
                <div class="meta-label">Category</div>
                <div class="meta-value"><%= book.category_name || 'General' %></div>
              </div>

              <div class="meta-item">
                <div class="meta-label">Book ID</div>
                <div class="meta-value">#<%= book.id %></div>
              </div>

              <div class="meta-item">
                <div class="meta-label">Best For</div>
                <div class="meta-value">Students & Readers</div>
              </div>
            </div>

            <div class="action-row">
              <a href="/cart/add/<%= book.id %>" class="action-btn">
                <i class="bi bi-cart-plus"></i> Add to Cart
              </a>

              <a href="/checkout" class="action-btn-outline">
                <i class="bi bi-lightning-charge"></i> Buy Now
              </a>
            </div>

            <div class="mini-note">
              <span class="chip"><i class="bi bi-shield-check"></i> Secure checkout</span>
              <span class="chip"><i class="bi bi-truck"></i> Fast order flow</span>
              <span class="chip"><i class="bi bi-arrow-repeat"></i> Easy tracking</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="info-card">
      <div class="section-title">Why Readers Like This Book</div>
      <div class="section-sub">A clean and professional summary section to make the page richer and more useful.</div>

      <div class="detail-grid">
        <div class="detail-box">
          <div class="detail-icon"><i class="bi bi-journal-richtext"></i></div>
          <h4>Useful Content</h4>
          <p>This book is displayed with structured information that helps readers understand the title quickly and confidently.</p>
        </div>

        <div class="detail-box">
          <div class="detail-icon"><i class="bi bi-lightning-charge"></i></div>
          <h4>Fast Browsing</h4>
          <p>Designed for smooth browsing, better previews, and rich UI interactions that make your bookstore feel modern.</p>
        </div>

        <div class="detail-box">
          <div class="detail-icon"><i class="bi bi-award"></i></div>
          <h4>Premium Feel</h4>
          <p>Large visuals, bold pricing, trust indicators, and responsive layout create a more professional reading experience.</p>
        </div>
      </div>
    </div>

    <% if (similar && similar.length) { %>
      <div class="related-wrap">
        <div class="related-head">
          <div>
            <div class="section-title">Related Books</div>
            <div class="section-sub">More books from a similar category you may like.</div>
          </div>

          <a href="/books?category=<%= encodeURIComponent(book.category_name || '') %>" class="related-link">
            View category <i class="bi bi-arrow-right"></i>
          </a>
        </div>

        <div class="row g-4">
          <% similar.forEach((b) => { 
            const sPrice = Math.max(0, Number(b.price || 0) - Math.round((Number(b.price || 0) * Number(b.discount || 0)) / 100));
          %>
            <div class="col-md-6 col-lg-3">
              <div class="book-card">
                <% if (Number(b.discount || 0) > 0) { %>
                  <div class="discount-badge"><%= b.discount %>% OFF</div>
                <% } %>

                <div class="book-cover">
                  <img
                    src="<%= b.image || '/uploads/default.png' %>"
                    alt="<%= b.name %>"
                    onerror="this.onerror=null;this.src='/uploads/default.png'"
                  >
                </div>

                <div class="quick-preview">
                  <div class="qp-title"><%= b.name %></div>
                  <div class="qp-author"><i class="bi bi-person"></i> <%= b.author %></div>
                  <div class="qp-stock"><i class="bi bi-box"></i> Stock: <%= b.available %></div>
                  <div class="qp-price">₹<%= sPrice %></div>

                  <div class="d-flex gap-2 mt-2">
                    <a href="/books/<%= b.id %>" class="btn btn-light btn-sm flex-fill">View</a>
                    <a href="/cart/add/<%= b.id %>" class="btn btn-primary btn-sm flex-fill">Add</a>
                  </div>
                </div>

                <div class="book-body">
                  <div class="mini-cat"><%= b.category_name || 'Book' %></div>
                  <div class="mini-title"><%= b.name %></div>
                  <div class="mini-author"><i class="bi bi-person"></i> <%= b.author %></div>
                  <div class="mini-price">₹<%= sPrice %></div>

                  <div class="mini-actions">
                    <a href="/books/<%= b.id %>" class="btn btn-outline-secondary mini-btn">View</a>
                    <a href="/cart/add/<%= b.id %>" class="btn btn-primary mini-btn">Add</a>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>

  <%- include('partials/footer') %>
</body>
</html>