<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Cart • BookHub</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <style>
    :root{
      --bh-bg:#f6f8fc;
      --bh-card:#ffffff;
      --bh-text:#0f172a;
      --bh-muted:#64748b;
      --bh-border:#e6eaf2;
      --bh-primary:#2563eb;
      --bh-primary2:#0ea5e9;
      --bh-danger:#ef4444;
      --bh-success:#16a34a;
      --bh-shadow:0 18px 45px rgba(15,23,42,.10);
      --bh-shadow2:0 10px 28px rgba(15,23,42,.08);
      --bh-radius:24px;
      --bh-radius2:30px;
    }

    *{box-sizing:border-box}
    html,body{overflow-x:hidden}

    body{
      background:
        radial-gradient(circle at top left, rgba(37,99,235,.10), transparent 22%),
        radial-gradient(circle at top right, rgba(14,165,233,.08), transparent 18%),
        linear-gradient(180deg,#f8fbff,#eef4ff);
      color:var(--bh-text);
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    .page-wrap{
      padding:26px 0 48px;
      position:relative;
      z-index:1;
    }

    .floating-shapes{
      position:fixed;
      inset:0;
      pointer-events:none;
      overflow:hidden;
      z-index:0;
    }

    .shape{
      position:absolute;
      border-radius:50%;
      filter:blur(10px);
      opacity:.22;
      animation:floatShape 12s ease-in-out infinite;
    }

    .shape.s1{
      width:180px;height:180px;
      background:rgba(37,99,235,.18);
      left:-40px;top:120px;
    }

    .shape.s2{
      width:220px;height:220px;
      background:rgba(14,165,233,.15);
      right:-60px;top:180px;
      animation-delay:2s;
    }

    .shape.s3{
      width:140px;height:140px;
      background:rgba(37,99,235,.12);
      left:20%;bottom:80px;
      animation-delay:4s;
    }

    @keyframes floatShape{
      0%,100%{transform:translateY(0) translateX(0)}
      50%{transform:translateY(-16px) translateX(8px)}
    }

    .hero-card,
    .cart-card,
    .summary-card,
    .empty-card{
      background:linear-gradient(135deg, rgba(255,255,255,.96), rgba(255,255,255,.90));
      border:1px solid rgba(255,255,255,.78);
      border-radius:var(--bh-radius2);
      box-shadow:var(--bh-shadow);
    }

    .hero-card{
      padding:24px;
      margin-bottom:22px;
      position:relative;
      overflow:hidden;
    }

    .hero-card::before{
      content:"";
      position:absolute;
      width:280px;
      height:280px;
      right:-90px;
      top:-90px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(37,99,235,.14), transparent 65%);
    }

    .hero-title{
      font-size:2.15rem;
      font-weight:900;
      line-height:1.1;
      margin-bottom:6px;
    }

    .hero-sub{
      color:var(--bh-muted);
      margin-bottom:0;
    }

    .top-actions{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
    }

    .top-actions .btn{
      border-radius:14px;
      font-weight:900;
      min-height:46px;
      padding:0 16px;
    }

    .cart-card{
      padding:22px;
    }

    .cart-item{
      display:grid;
      grid-template-columns:110px 1fr 120px;
      gap:18px;
      padding:18px 0;
      border-bottom:1px solid #edf2f9;
      align-items:start;
      transition:.25s ease;
    }

    .cart-item:hover{
      transform:translateY(-2px);
    }

    .cart-item:last-child{
      border-bottom:none;
    }

    .item-image-wrap{
      display:flex;
      justify-content:center;
      align-items:center;
      background:linear-gradient(180deg,#f8fbff,#ffffff);
      border:1px solid var(--bh-border);
      border-radius:20px;
      padding:10px;
      min-height:138px;
      box-shadow:var(--bh-shadow2);
    }

    .item-image{
      width:82px;
      height:112px;
      object-fit:cover;
      border-radius:14px;
      background:#fff;
      border:1px solid rgba(0,0,0,.05);
      box-shadow:0 12px 24px rgba(15,23,42,.12);
    }

    .item-category{
      color:var(--bh-primary);
      font-size:.8rem;
      font-weight:800;
      margin-bottom:4px;
      text-transform:capitalize;
    }

    .item-title{
      font-size:1.08rem;
      font-weight:900;
      line-height:1.35;
      margin-bottom:4px;
    }

    .item-author{
      color:var(--bh-muted);
      font-size:.92rem;
      margin-bottom:10px;
    }

    .price-row{
      display:flex;
      align-items:center;
      gap:10px;
      flex-wrap:wrap;
      margin-bottom:10px;
    }

    .price-now{
      color:var(--bh-primary);
      font-size:1.18rem;
      font-weight:900;
    }

    .price-old{
      color:#94a3b8;
      text-decoration:line-through;
      font-weight:800;
      font-size:.95rem;
    }

    .discount-chip{
      display:inline-flex;
      align-items:center;
      gap:6px;
      padding:5px 10px;
      border-radius:999px;
      background:#fee2e2;
      color:#b91c1c;
      font-size:.76rem;
      font-weight:900;
    }

    .sub-row{
      display:flex;
      align-items:center;
      gap:16px;
      flex-wrap:wrap;
      margin-top:8px;
    }

    .stock-info{
      display:inline-flex;
      align-items:center;
      gap:8px;
      color:#334155;
      font-size:.84rem;
      font-weight:700;
    }

    .qty-wrap{
      display:flex;
      align-items:center;
      gap:8px;
      background:#fff;
      border:1px solid var(--bh-border);
      border-radius:999px;
      padding:5px;
      box-shadow:var(--bh-shadow2);
    }

    .qty-btn{
      width:34px;
      height:34px;
      border-radius:50%;
      display:grid;
      place-items:center;
      text-decoration:none;
      color:var(--bh-text);
      background:#f8fbff;
      border:1px solid #e4ecfa;
      font-weight:900;
      transition:.2s ease;
    }

    .qty-btn:hover{
      background:#eef4ff;
      color:var(--bh-primary);
    }

    .qty-count{
      min-width:26px;
      text-align:center;
      font-weight:900;
    }

    .remove-link{
      display:inline-flex;
      align-items:center;
      gap:8px;
      color:#dc2626;
      text-decoration:none;
      font-weight:800;
      font-size:.88rem;
    }

    .item-total{
      text-align:right;
      display:flex;
      flex-direction:column;
      align-items:flex-end;
      justify-content:space-between;
      min-height:100%;
    }

    .line-total{
      font-size:1.25rem;
      font-weight:900;
      color:#111827;
    }

    .save-note{
      color:var(--bh-success);
      font-size:.82rem;
      font-weight:800;
    }

    .summary-card{
      padding:22px;
      position:sticky;
      top:20px;
      overflow:hidden;
    }

    .summary-card::before{
      content:"";
      position:absolute;
      width:220px;
      height:220px;
      right:-70px;
      top:-70px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(37,99,235,.12), transparent 70%);
      pointer-events:none;
    }

    .summary-pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      background:#eef4ff;
      color:var(--bh-primary);
      font-size:.82rem;
      font-weight:900;
      margin-bottom:12px;
    }

    .summary-title{
      font-size:1.22rem;
      font-weight:900;
      margin-bottom:6px;
    }

    .summary-sub{
      color:var(--bh-muted);
      margin-bottom:16px;
      font-size:.92rem;
    }

    .summary-row{
      display:flex;
      justify-content:space-between;
      gap:10px;
      margin-bottom:12px;
      color:#334155;
      font-weight:700;
    }

    .summary-total{
      display:flex;
      justify-content:space-between;
      gap:10px;
      border-top:1px solid #e6edf7;
      padding-top:14px;
      margin-top:14px;
      font-size:1.24rem;
      font-weight:900;
      color:#111827;
    }

    .checkout-btn{
      width:100%;
      min-height:54px;
      border:none;
      border-radius:18px;
      margin-top:16px;
      background:linear-gradient(135deg,#0f172a,#2563eb);
      color:#fff;
      font-weight:900;
      box-shadow:0 18px 30px rgba(37,99,235,.20);
      transition:.25s ease;
    }

    .checkout-btn:hover{
      transform:translateY(-2px);
    }

    .summary-note{
      margin-top:12px;
      display:flex;
      align-items:flex-start;
      gap:8px;
      padding:12px;
      border-radius:16px;
      background:#f8fbff;
      border:1px solid #e6edf7;
      color:#475569;
      font-size:.84rem;
      font-weight:700;
    }

    .empty-card{
      padding:42px 24px;
      text-align:center;
    }

    .empty-icon{
      width:88px;
      height:88px;
      margin:0 auto 16px;
      border-radius:24px;
      display:grid;
      place-items:center;
      background:#eef4ff;
      color:var(--bh-primary);
      font-size:2rem;
    }

    .empty-card h3{
      font-size:1.6rem;
      font-weight:900;
      margin-bottom:8px;
    }

    .empty-card p{
      color:var(--bh-muted);
      margin-bottom:18px;
    }

    .empty-card .btn{
      border-radius:16px;
      font-weight:900;
      min-height:50px;
      padding:0 18px;
    }

    @media (max-width: 991px){
      .cart-item{
        grid-template-columns:100px 1fr;
      }

      .item-total{
        grid-column:1 / -1;
        flex-direction:row;
        align-items:center;
        justify-content:space-between;
        padding-top:8px;
      }
    }

    @media (max-width: 767px){
      .hero-card,
      .cart-card,
      .summary-card,
      .empty-card{
        border-radius:24px;
      }

      .hero-title{
        font-size:1.8rem;
      }

      .cart-item{
        grid-template-columns:1fr;
        gap:14px;
      }

      .item-image-wrap{
        max-width:180px;
      }

      .item-total{
        align-items:flex-start;
        flex-direction:column;
        gap:8px;
      }

      .top-actions{
        width:100%;
      }

      .top-actions .btn{
        flex:1;
      }
    }
  </style>
</head>
<body>

  <div class="floating-shapes">
    <span class="shape s1"></span>
    <span class="shape s2"></span>
    <span class="shape s3"></span>
  </div>

  <%- include('partials/navbar') %>

  <div class="container page-wrap">
    <div class="hero-card d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <div class="hero-title">Your Cart</div>
        <p class="hero-sub">Review your selected books before checkout and continue with a cleaner premium flow.</p>
      </div>

      <div class="top-actions">
        <a href="/books" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-left"></i> Continue Shopping
        </a>

        <% if (cart.length) { %>
          <a href="/cart/clear" class="btn btn-outline-danger" onclick="return confirm('Clear full cart?')">
            <i class="bi bi-trash"></i> Clear Cart
          </a>
        <% } %>
      </div>
    </div>

    <% if (!cart.length) { %>
      <div class="empty-card">
        <div class="empty-icon">
          <i class="bi bi-cart-x"></i>
        </div>
        <h3>Your cart is empty</h3>
        <p>Add books to your cart and come back here to continue your premium checkout journey.</p>
        <a href="/books" class="btn btn-primary">
          <i class="bi bi-book"></i> Browse Books
        </a>
      </div>
    <% } else { %>
      <div class="row g-4">
        <div class="col-lg-8">
          <div class="cart-card">
            <% cart.forEach((item) => { %>
              <div class="cart-item">
                <div class="item-image-wrap">
                  <img
                    src="<%= item.image || '/uploads/default.png' %>"
                    alt="<%= item.name %>"
                    class="item-image"
                    onerror="this.onerror=null;this.src='/uploads/default.png'"
                  >
                </div>

                <div>
                  <div class="item-category"><%= item.category_name || 'Book' %></div>
                  <div class="item-title"><%= item.name %></div>
                  <div class="item-author"><i class="bi bi-person"></i> <%= item.author %></div>

                  <div class="price-row">
                    <span class="price-now">₹<%= item.finalPrice %></span>

                    <% if (Number(item.discount || 0) > 0) { %>
                      <span class="price-old">₹<%= item.price %></span>
                      <span class="discount-chip"><%= item.discount %>% OFF</span>
                    <% } %>
                  </div>

                  <div class="sub-row">
                    <div class="qty-wrap">
                      <a href="/cart/decrease/<%= item.id %>" class="qty-btn">-</a>
                      <div class="qty-count"><%= item.qty %></div>
                      <a href="/cart/increase/<%= item.id %>" class="qty-btn">+</a>
                    </div>

                    <div class="stock-info">
                      <i class="bi bi-box-seam"></i> Stock: <%= item.available %>
                    </div>

                    <a href="/cart/remove/<%= item.id %>" class="remove-link">
                      <i class="bi bi-trash"></i> Remove
                    </a>
                  </div>
                </div>

                <div class="item-total">
                  <div class="line-total">₹<%= item.lineTotal %></div>
                  <% if (Number(item.discount || 0) > 0) { %>
                    <div class="save-note">You save ₹<%= (Number(item.price || 0) - Number(item.finalPrice || 0)) * Number(item.qty || 0) %></div>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="col-lg-4">
          <div class="summary-card">
            <div class="summary-pill">
              <i class="bi bi-shield-lock"></i> Secure cart summary
            </div>

            <div class="summary-title">Order Summary</div>
            <div class="summary-sub">A quick premium summary of your selected books.</div>

            <div class="summary-row">
              <span>Items</span>
              <span><%= cart.length %></span>
            </div>

            <div class="summary-row">
              <span>Shipping</span>
              <span>Free</span>
            </div>

            <div class="summary-row">
              <span>Platform Fee</span>
              <span>₹0</span>
            </div>

            <div class="summary-total">
              <span>Total</span>
              <span>₹<%= subtotal %></span>
            </div>

            <a href="/checkout" class="text-decoration-none">
              <button class="checkout-btn">
                <i class="bi bi-bag-check"></i> Proceed to Checkout
              </button>
            </a>

            <div class="summary-note">
              <i class="bi bi-info-circle"></i>
              <span>Your order will continue to the next step where you can enter delivery details and choose payment method.</span>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </div>
  <%- include('partials/footer') %>
</body>
</html>