<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Order Details • BookHub</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/navbar.css">
  <link rel="stylesheet" href="/css/common-footer.css">

  <style>
    :root{
      --bh-text:#0f172a;
      --bh-muted:#64748b;
      --bh-border:#e6eaf2;
      --bh-primary:#2563eb;
      --bh-primary2:#0ea5e9;
      --bh-success:#16a34a;
      --bh-warning:#d97706;
      --bh-danger:#ef4444;
      --bh-shadow:0 18px 45px rgba(15,23,42,.10);
      --bh-shadow2:0 10px 28px rgba(15,23,42,.08);
      --bh-radius:24px;
      --bh-radius2:30px;
    }

    *{box-sizing:border-box}
    html,body{overflow-x:hidden}

    body{
      background:
        radial-gradient(circle at top left, rgba(37,99,235,.10), transparent 22%),
        radial-gradient(circle at top right, rgba(14,165,233,.08), transparent 18%),
        linear-gradient(180deg,#f8fbff,#eef4ff);
      color:var(--bh-text);
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    }

    .page-wrap{
      padding:26px 0 48px;
      position:relative;
      z-index:1;
    }

    .floating-shapes{
      position:fixed;
      inset:0;
      pointer-events:none;
      overflow:hidden;
      z-index:0;
    }

    .shape{
      position:absolute;
      border-radius:50%;
      filter:blur(10px);
      opacity:.22;
      animation:floatShape 12s ease-in-out infinite;
    }

    .shape.s1{
      width:180px;height:180px;
      background:rgba(37,99,235,.18);
      left:-40px;top:120px;
    }

    .shape.s2{
      width:220px;height:220px;
      background:rgba(14,165,233,.15);
      right:-60px;top:180px;
      animation-delay:2s;
    }

    .shape.s3{
      width:140px;height:140px;
      background:rgba(37,99,235,.12);
      left:20%;bottom:80px;
      animation-delay:4s;
    }

    @keyframes floatShape{
      0%,100%{transform:translateY(0) translateX(0)}
      50%{transform:translateY(-16px) translateX(8px)}
    }

    .hero-card,
    .glass-card{
      background:linear-gradient(135deg, rgba(255,255,255,.96), rgba(255,255,255,.90));
      border:1px solid rgba(255,255,255,.78);
      border-radius:var(--bh-radius2);
      box-shadow:var(--bh-shadow);
    }

    .hero-card{
      padding:24px;
      margin-bottom:22px;
      position:relative;
      overflow:hidden;
    }

    .hero-card::before{
      content:"";
      position:absolute;
      width:280px;
      height:280px;
      right:-90px;
      top:-90px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(37,99,235,.14), transparent 65%);
    }

    .hero-title{
      font-size:2.1rem;
      font-weight:900;
      line-height:1.1;
      margin-bottom:6px;
    }

    .hero-sub{
      color:var(--bh-muted);
      margin-bottom:0;
    }

    .hero-actions{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
    }

    .back-btn{
      border-radius:14px;
      font-weight:900;
      min-height:46px;
      padding:0 16px;
    }

    .glass-card{
      padding:22px;
      margin-bottom:20px;
    }

    .section-title{
      font-size:1.22rem;
      font-weight:900;
      margin-bottom:6px;
    }

    .section-sub{
      color:var(--bh-muted);
      margin-bottom:18px;
      font-size:.93rem;
    }

    .top-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:16px;
    }

    .info-box{
      background:#fff;
      border:1px solid var(--bh-border);
      border-radius:22px;
      padding:18px;
      box-shadow:var(--bh-shadow2);
      height:100%;
    }

    .info-label{
      color:var(--bh-muted);
      font-size:.8rem;
      font-weight:800;
      margin-bottom:4px;
      text-transform:uppercase;
      letter-spacing:.3px;
    }

    .info-value{
      color:#111827;
      font-weight:900;
      margin-bottom:10px;
      word-break:break-word;
    }

    .status-pill{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:8px 12px;
      border-radius:999px;
      font-size:.78rem;
      font-weight:900;
      min-width:120px;
    }

    .st-placed{background:#dbeafe;color:#1d4ed8}
    .st-paid{background:#dcfce7;color:#166534}
    .st-shipped{background:#ede9fe;color:#6d28d9}
    .st-out{background:#fef3c7;color:#b45309}
    .st-delivered{background:#dcfce7;color:#166534}
    .st-cancelled{background:#fee2e2;color:#b91c1c}
    .st-default{background:#e5e7eb;color:#475569}

    .track-wrap{
      display:grid;
      grid-template-columns:repeat(5,1fr);
      gap:12px;
    }

    .track-step{
      position:relative;
      text-align:center;
      padding:14px 10px;
      border-radius:18px;
      border:1px solid var(--bh-border);
      background:#fff;
      box-shadow:var(--bh-shadow2);
      font-weight:800;
      color:#64748b;
      min-height:72px;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .track-step.active{
      background:#eef4ff;
      color:var(--bh-primary);
      border-color:#cfe0ff;
    }

    .track-step.done{
      background:#dcfce7;
      color:#166534;
      border-color:#bbf7d0;
    }

    .track-step.cancelled{
      background:#fee2e2;
      color:#b91c1c;
      border-color:#fecaca;
    }

    .order-book{
      display:grid;
      grid-template-columns:92px 1fr 90px;
      gap:16px;
      align-items:start;
      padding:16px;
      border:1px solid var(--bh-border);
      border-radius:22px;
      background:#fff;
      box-shadow:var(--bh-shadow2);
      margin-bottom:14px;
    }

    .order-book:last-child{
      margin-bottom:0;
    }

    .book-img-wrap{
      display:flex;
      justify-content:center;
      align-items:center;
      background:linear-gradient(180deg,#f8fbff,#ffffff);
      border:1px solid var(--bh-border);
      border-radius:18px;
      padding:8px;
      min-height:120px;
    }

    .book-img{
      width:72px;
      height:98px;
      object-fit:cover;
      border-radius:12px;
      background:#fff;
      border:1px solid rgba(0,0,0,.05);
      box-shadow:0 10px 20px rgba(15,23,42,.10);
    }

    .book-title{
      font-size:1.03rem;
      font-weight:900;
      margin-bottom:4px;
      line-height:1.35;
    }

    .book-author{
      color:var(--bh-muted);
      font-size:.92rem;
      margin-bottom:8px;
    }

    .book-meta{
      display:flex;
      gap:14px;
      flex-wrap:wrap;
      color:#334155;
      font-size:.84rem;
      font-weight:700;
    }

    .book-price{
      text-align:right;
      font-size:1.15rem;
      font-weight:900;
      color:var(--bh-primary);
    }

    .summary-card{
      background:#fff;
      border:1px solid var(--bh-border);
      border-radius:22px;
      padding:18px;
      box-shadow:var(--bh-shadow2);
      margin-bottom:16px;
    }

    .summary-row{
      display:flex;
      justify-content:space-between;
      gap:10px;
      margin-bottom:12px;
      color:#334155;
      font-weight:700;
    }

    .summary-total{
      display:flex;
      justify-content:space-between;
      gap:10px;
      border-top:1px solid #e6edf7;
      padding-top:14px;
      margin-top:14px;
      font-size:1.2rem;
      font-weight:900;
      color:#111827;
    }

    .address-box{
      background:#fff;
      border:1px solid var(--bh-border);
      border-radius:22px;
      padding:18px;
      box-shadow:var(--bh-shadow2);
    }

    .address-box strong{
      display:block;
      margin-bottom:6px;
      font-size:1rem;
    }

    .address-box p{
      margin:0;
      color:#475569;
      line-height:1.7;
      word-break:break-word;
    }

    @media (max-width: 991px){
      .top-grid{
        grid-template-columns:1fr;
      }

      .track-wrap{
        grid-template-columns:1fr 1fr;
      }

      .order-book{
        grid-template-columns:92px 1fr;
      }

      .book-price{
        grid-column:1 / -1;
        text-align:left;
      }
    }

    @media (max-width: 767px){
      .hero-card,
      .glass-card{
        border-radius:24px;
      }

      .hero-title{
        font-size:1.8rem;
      }

      .track-wrap{
        grid-template-columns:1fr;
      }

      .order-book{
        grid-template-columns:1fr;
      }

      .book-img-wrap{
        max-width:160px;
      }

      .hero-actions{
        width:100%;
      }

      .hero-actions .btn,
      .hero-actions form{
        width:100%;
      }

      .hero-actions form .btn{
        width:100%;
      }
    }
  </style>
</head>
<body>

  <div class="floating-shapes">
    <span class="shape s1"></span>
    <span class="shape s2"></span>
    <span class="shape s3"></span>
  </div>

  <%- include('partials/navbar') %>

  <div class="container page-wrap">
    <div class="hero-card d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <div class="hero-title">Order Details</div>
        <p class="hero-sub">View ordered books, delivery details, payment mode, and tracking status.</p>
      </div>

      <div class="hero-actions">
        <a href="/my-orders" class="btn btn-outline-secondary back-btn">
          <i class="bi bi-arrow-left"></i> Back to Orders
        </a>

        <a href="/my-orders/<%= order.id %>/invoice" class="btn btn-dark back-btn">
          <i class="bi bi-download"></i> Invoice
        </a>

        <% if (order.status === "PLACED" || order.status === "PAID") { %>
          <form action="/my-orders/<%= order.id %>/cancel" method="POST" style="display:inline;">
            <button class="btn btn-outline-danger back-btn" onclick="return confirm('Cancel this order?')">
              <i class="bi bi-x-circle"></i> Cancel Order
            </button>
          </form>
        <% } %>
      </div>
    </div>

    <div class="glass-card">
      <div class="section-title">Order Overview</div>
      <div class="section-sub">Basic order information and current payment state.</div>

      <div class="top-grid">
        <div class="info-box">
          <div class="info-label">Order ID</div>
          <div class="info-value">#<%= order.id %></div>

          <div class="info-label">Order Date</div>
          <div class="info-value"><%= new Date(order.created_at).toLocaleString() %></div>

          <div class="info-label">Payment Method</div>
          <div class="info-value"><%= order.payment_method || 'COD' %></div>

          <% if (order.payment_id) { %>
            <div class="info-label">Payment ID</div>
            <div class="info-value"><%= order.payment_id %></div>
          <% } %>
        </div>

        <div class="info-box">
          <div class="info-label">Current Status</div>
          <%
            let statusClass = "st-default";
            if (order.status === "PLACED") statusClass = "st-placed";
            else if (order.status === "PAID") statusClass = "st-paid";
            else if (order.status === "SHIPPED") statusClass = "st-shipped";
            else if (order.status === "OUT_FOR_DELIVERY") statusClass = "st-out";
            else if (order.status === "DELIVERED") statusClass = "st-delivered";
            else if (order.status === "CANCELLED") statusClass = "st-cancelled";
          %>
          <div class="status-pill <%= statusClass %>"><%= order.status %></div>

          <div class="info-label mt-3">Total Amount</div>
          <div class="info-value">₹<%= order.total %></div>

          <div class="info-label">Customer</div>
          <div class="info-value"><%= order.full_name || order.fullname || 'Customer' %></div>
        </div>
      </div>
    </div>

    <div class="glass-card">
      <div class="section-title">Order Tracking</div>
      <div class="section-sub">Track your order journey from placement to delivery.</div>

      <%
        const current = String(order.status || "");
        const placedDone = ["PLACED","PAID","SHIPPED","OUT_FOR_DELIVERY","DELIVERED"].includes(current);
        const paidDone = ["PAID","SHIPPED","OUT_FOR_DELIVERY","DELIVERED"].includes(current);
        const shippedDone = ["SHIPPED","OUT_FOR_DELIVERY","DELIVERED"].includes(current);
        const outDone = ["OUT_FOR_DELIVERY","DELIVERED"].includes(current);
        const deliveredDone = ["DELIVERED"].includes(current);
      %>

      <% if (current === "CANCELLED") { %>
        <div class="track-wrap">
          <div class="track-step done">PLACED</div>
          <div class="track-step cancelled">CANCELLED</div>
        </div>
      <% } else { %>
        <div class="track-wrap">
          <div class="track-step <%= placedDone ? 'done' : (current === 'PLACED' ? 'active' : '') %>">PLACED</div>
          <div class="track-step <%= paidDone ? 'done' : (current === 'PAID' ? 'active' : '') %>">PAID</div>
          <div class="track-step <%= shippedDone ? 'done' : (current === 'SHIPPED' ? 'active' : '') %>">SHIPPED</div>
          <div class="track-step <%= outDone ? 'done' : (current === 'OUT_FOR_DELIVERY' ? 'active' : '') %>">OUT FOR DELIVERY</div>
          <div class="track-step <%= deliveredDone ? 'done' : (current === 'DELIVERED' ? 'active' : '') %>">DELIVERED</div>
        </div>
      <% } %>
    </div>

    <div class="row g-4">
      <div class="col-lg-8">
        <div class="glass-card">
          <div class="section-title">Books in This Order</div>
          <div class="section-sub">All books included in your purchase.</div>

          <% items.forEach((item) => { %>
            <div class="order-book">
              <div class="book-img-wrap">
                <img
                  src="<%= item.image || '/uploads/default.png' %>"
                  alt="<%= item.name %>"
                  class="book-img"
                  onerror="this.onerror=null;this.src='/uploads/default.png'"
                >
              </div>

              <div>
                <div class="book-title"><%= item.name %></div>
                <div class="book-author"><i class="bi bi-person"></i> <%= item.author %></div>

                <div class="book-meta">
                  <span><i class="bi bi-box"></i> Qty: <%= item.qty %></span>
                  <span><i class="bi bi-tag"></i> Price Each: ₹<%= item.price_each %></span>
                </div>
              </div>

              <div class="book-price">₹<%= Number(item.price_each || 0) * Number(item.qty || 0) %></div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="summary-card">
          <div class="section-title">Order Summary</div>

          <div class="summary-row">
            <span>Items Total</span>
            <span>₹<%= itemsTotal %></span>
          </div>

          <div class="summary-row">
            <span>Shipping</span>
            <span>Free</span>
          </div>

          <div class="summary-row">
            <span>Payment</span>
            <span><%= order.payment_method || 'COD' %></span>
          </div>

          <div class="summary-total">
            <span>Grand Total</span>
            <span>₹<%= order.total %></span>
          </div>
        </div>

        <div class="address-box">
          <div class="section-title mb-2">Delivery Address</div>
          <strong><%= order.full_name || order.fullname || 'Customer' %></strong>
          <p>
            <%= order.email_address || order.email || '' %><br>
            <%= order.phone || 'Phone not available' %><br>
            <%= order.address_line || 'Address not available' %><br>
            <%= order.city || '' %> <%= order.pincode || '' %>
          </p>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>